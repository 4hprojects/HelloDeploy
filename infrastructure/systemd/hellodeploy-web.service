[Unit]
Description=HelloDeploy web application
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=hellodeploy-web
Group=hellodeploy-config
WorkingDirectory=/opt/hellodeploy
Environment=NODE_ENV=production
ExecStart=/usr/bin/node apps/web/src/server.js
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/log/hellodeploy

[Install]
WantedBy=multi-user.target
