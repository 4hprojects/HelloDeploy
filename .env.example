# ─────────────────────────────────────────────
# HelloDeploy — Environment Configuration Example
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ── Session ───────────────────────────────────
# 64-byte hex string: openssl rand -hex 64
SESSION_SECRET=

# ── MongoDB Atlas ─────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hellodeploy?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Resend (email) ────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@hellodeploy.online

# ── Cloudflare Turnstile ──────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── GitHub App ────────────────────────────────
# Register at https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_APP_NAME=                          # App slug shown in Settings > GitHub Apps
GITHUB_APP_PRIVATE_KEY_PATH=/etc/hellodeploy/github-app.pem
# Alternative: inline PEM with \n escapes instead of a file path
# GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────
# AES-256-GCM master key (base64-encoded 32 bytes).
# Generate with: node scripts/generate-secrets.js
# Must NOT be stored in MongoDB or source control.  Back up separately.
HELLODEPLOY_MASTER_KEY=

# ── Platform ──────────────────────────────────
PLATFORM_DOMAIN=hellodeploy.online
PLATFORM_SUBDOMAIN_SUFFIX=.apps.hellodeploy.online

# ── Worker ────────────────────────────────────
WORKER_CONCURRENCY=1
BUILD_TIMEOUT_MS=600000
BUILD_WORKSPACE_ROOT=/var/lib/hellodeploy/builds
RELEASE_METADATA_ROOT=/var/lib/hellodeploy/releases
PROJECT_VOLUME_ROOT=/var/lib/hellodeploy/projects
NGINX_HELLODEPLOY_CONFIG_DIR=/etc/nginx/hellodeploy.d
NGINX_ENABLED=false

# ── Deployment ─────────────────────────────────
# Port range for container allocation (inclusive)
PORT_RANGE_START=4000
PORT_RANGE_END=4999
