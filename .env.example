# ─────────────────────────────────────────────
# HelloDeploy — Environment Configuration Example
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=localhost

# ── Session ───────────────────────────────────
# 64-byte hex string: openssl rand -hex 64
SESSION_SECRET=

# ── MongoDB Atlas ─────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hellodeploy?retryWrites=true&w=majority

# ── Redis ─────────────────────────────────────
# Managed/hybrid deployments should use rediss://. When set, REDIS_URL takes
# precedence over the legacy host/port/password values below.
# REDIS_URL=rediss://<user>:<password>@<host>:<port>/0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Resend (optional email integration) ───────
# Leave RESEND_API_KEY empty to disable outbound email.
RESEND_API_KEY=
EMAIL_FROM=noreply@hellodeploy.online

# ── Cloudflare Turnstile (optional) ───────────
# Configure both keys or leave both empty.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── GitHub App (required for repository deploys) ──
# The platform can start without this integration, but repository connection,
# webhooks, and deployments require the complete group below.
# Register at https://github.com/settings/apps/new
GITHUB_APP_ID=
GITHUB_APP_NAME=                          # App slug shown in Settings > GitHub Apps
GITHUB_APP_PRIVATE_KEY_PATH=
# Alternative: inline PEM with \n escapes instead of a file path
# GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Encryption ────────────────────────────────
# AES-256-GCM master key (base64-encoded 32 bytes).
# Generate with: node scripts/generate-secrets.js
# Must NOT be stored in MongoDB or source control.  Back up separately.
HELLODEPLOY_MASTER_KEY=

# ── Platform ──────────────────────────────────
# Dashboard/authentication hostname used by the web service.
PLATFORM_DOMAIN=hellodeploy.online
# Wildcard routing base used by the deployment worker: <slug>.<domain>.
DEPLOYMENT_DOMAIN=apps.hellodeploy.online
# Display suffix used by the dashboard; keep aligned with DEPLOYMENT_DOMAIN.
PLATFORM_SUBDOMAIN_SUFFIX=.apps.hellodeploy.online

# ── Worker ────────────────────────────────────
WORKER_CONCURRENCY=1
BUILD_TIMEOUT_MS=600000
BUILD_WORKSPACE_ROOT=/var/lib/hellodeploy/builds
RELEASE_METADATA_ROOT=/var/lib/hellodeploy/releases
PROJECT_VOLUME_ROOT=/var/lib/hellodeploy/projects
NGINX_HELLODEPLOY_CONFIG_DIR=/etc/nginx/hellodeploy.d
NGINX_BINARY_PATH=/usr/sbin/nginx
NGINX_HELPER_SOCKET=/run/hellodeploy/nginx-helper.sock
NGINX_HELPER_TIMEOUT_MS=15000
NGINX_ENABLED=true
# V1 production requires the installed local Nginx helper. Development may
# override this to false when public application routing is not being tested.

# ── Deployment ─────────────────────────────────
# Port range for container allocation (inclusive)
PORT_RANGE_START=10000
PORT_RANGE_END=19999
