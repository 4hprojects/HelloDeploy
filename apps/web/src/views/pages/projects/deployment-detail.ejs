<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">
      Deployment #<%= deployment.sequenceNumber %>
      <%- include('../../partials/status-badge', { status: deployment.status }) %>
    </h1>
    <p class="page-header__subtitle text-muted text-sm">
      <a href="/projects/<%= project.slug %>/deployments" class="table-link">&larr; All Deployments</a>
    </p>
  </div>
  <% const canAct = membership.role === 'OWNER' || membership.role === 'MAINTAINER'; %>
  <% const isActive = ['QUEUED','VALIDATING','BUILDING','DEPLOYING'].includes(deployment.status); %>
  <% const isRetryable = ['FAILED','CANCELLED'].includes(deployment.status); %>
  <div class="button-group">
    <% if (isActive && canAct) { %>
    <form method="POST" action="/projects/<%= project.slug %>/deployments/<%= deployment._id %>/cancel"
          data-confirm='Cancel this deployment?'>
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--danger button--sm" data-tooltip="Cancel this deployment before it completes.">Cancel</button>
    </form>
    <% } %>
    <% if (isRetryable && canAct) { %>
    <form method="POST" action="/projects/<%= project.slug %>/deployments/<%= deployment._id %>/retry">
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--secondary button--sm" data-tooltip="Queue another deployment attempt for this commit.">Retry</button>
    </form>
    <% } %>
  </div>
</div>

<!-- Deployment info cards -->
<div class="card-grid card-grid--3 mb-6">
  <div class="card">
    <div class="card__body">
      <p class="text-muted text-xs mb-1">Commit</p>
      <code class="code-inline"><%= deployment.commitSha ? deployment.commitSha.slice(0, 7) : '—' %></code>
      <% if (deployment.commitMessage) { %>
      <p class="text-sm mt-1"><%= deployment.commitMessage.slice(0, 80) %></p>
      <% } %>
    </div>
  </div>
  <div class="card">
    <div class="card__body">
      <p class="text-muted text-xs mb-1">Trigger</p>
      <p class="text-sm font-medium"><%= deployment.triggerType %></p>
      <% if (deployment.sourceDeploymentId) { %>
      <p class="text-muted text-xs">from deployment #<%= deployment.sourceDeploymentId %></p>
      <% } %>
    </div>
  </div>
  <div class="card">
    <div class="card__body">
      <p class="text-muted text-xs mb-1">Duration</p>
      <% if (deployment.startedAt && deployment.completedAt) { %>
        <% const ms = new Date(deployment.completedAt) - new Date(deployment.startedAt); %>
        <% const secs = Math.round(ms / 1000); %>
        <p class="text-sm font-medium"><%= secs < 60 ? `${secs}s` : `${Math.floor(secs/60)}m ${secs%60}s` %></p>
      <% } else if (deployment.startedAt) { %>
        <p class="text-sm font-medium text-muted">In progress…</p>
      <% } else { %>
        <p class="text-sm text-muted">—</p>
      <% } %>
    </div>
  </div>
</div>

<!-- Stage timeline -->
<div class="card mb-6">
  <div class="card__header">
    <h2 class="card__title text-sm">Deployment Timeline</h2>
  </div>
  <div class="card__body">
    <%
      const terminalStatuses = ['FAILED','CANCELLED','HEALTHY','ROLLED_BACK'];
      const eventStageToStatus = { VALIDATE: 'VALIDATING', BUILD: 'BUILDING', DEPLOY: 'DEPLOYING' };
      const statusOrder = { QUEUED: 0, VALIDATING: 1, BUILDING: 2, DEPLOYING: 3, HEALTHY: 4, FAILED: 4, CANCELLED: 4, ROLLED_BACK: 4 };
      const timelineStages = [
        { key: 'QUEUED', label: 'Queued', detail: 'Waiting for a deployment worker.', eventStages: [] },
        { key: 'VALIDATING', label: 'Validate', detail: 'Repository, build context, and Dockerfile checks.', eventStages: ['VALIDATE'] },
        { key: 'BUILDING', label: 'Build', detail: 'Container image build and artifact preparation.', eventStages: ['BUILD'] },
        { key: 'DEPLOYING', label: 'Deploy', detail: 'Container startup, health checks, and routing.', eventStages: ['DEPLOY'] },
        { key: 'HEALTHY', label: 'Healthy', detail: 'Release is live and serving traffic.', eventStages: ['DEPLOY'] },
      ];
      const eventsForStage = (stage) => events.filter((ev) => stage.eventStages.includes(ev.stage));
      const firstEventForStage = (stage) => eventsForStage(stage)[0] ?? null;
      const latestEventForStage = (stage) => eventsForStage(stage).slice(-1)[0] ?? null;
      const latestErrorEvent = events.filter((ev) => ev.level === 'ERROR').slice(-1)[0] ?? null;
      const failedStageKey = latestErrorEvent ? eventStageToStatus[latestErrorEvent.stage] : deployment.status;
      const currentOrder = statusOrder[deployment.status] ?? 0;
      const isTerminalStatus = terminalStatuses.includes(deployment.status);
      const failedStageOrder = statusOrder[failedStageKey] ?? currentOrder;
      const stageTime = (stage, firstEvent) => {
        if (stage.key === 'QUEUED') return deployment.startedAt;
        if (stage.key === 'HEALTHY' && deployment.completedAt && deployment.status === 'HEALTHY') return deployment.completedAt;
        return firstEvent?.createdAt ?? null;
      };
      const stageState = (stage) => {
        const order = statusOrder[stage.key] ?? 0;
        if (['FAILED','CANCELLED','ROLLED_BACK'].includes(deployment.status)) {
          if (stage.key === failedStageKey) return 'failed';
          return order < failedStageOrder ? 'complete' : 'pending';
        }
        if (deployment.status === 'HEALTHY' && stage.key === 'HEALTHY') return 'complete';
        if (!isTerminalStatus && stage.key === deployment.status) return 'active';
        if (order < currentOrder) return 'complete';
        return 'pending';
      };
    %>
    <div class="deployment-timeline">
      <% timelineStages.forEach((stage, i) => { %>
        <%
          const state = stageState(stage);
          const firstEvent = firstEventForStage(stage);
          const latestEvent = latestEventForStage(stage);
          const startedAt = stageTime(stage, firstEvent);
          const statusText = state === 'active' ? 'In progress' : state === 'complete' ? 'Complete' : state === 'failed' ? deployment.status.replace('_', ' ') : 'Pending';
          const message = state === 'failed' && deployment.failureSummary ? deployment.failureSummary : latestEvent?.messageRedacted ?? stage.detail;
        %>
        <div class="deployment-stage deployment-stage--<%= state %>" data-stage-key="<%= stage.key %>">
          <div class="deployment-stage__marker" aria-hidden="true">
            <span class="deployment-stage__dot"></span>
          </div>
          <div class="deployment-stage__content">
            <div class="deployment-stage__heading">
              <span class="deployment-stage__label"><%= stage.label %></span>
              <span class="deployment-stage__status" data-stage-status><%= statusText %></span>
            </div>
            <p class="deployment-stage__message" data-stage-message><%= message %></p>
            <p class="deployment-stage__time text-muted" data-stage-time>
              <% if (startedAt) { %>
                <%= new Date(startedAt).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
              <% } else { %>
                —
              <% } %>
            </p>
          </div>
        </div>
        <% if (i < timelineStages.length - 1) { %>
          <div class="deployment-stage__connector <%= stageState(timelineStages[i + 1]) !== 'pending' ? 'connector--complete' : '' %>"></div>
        <% } %>
      <% }) %>
    </div>
    <% if (deployment.failureCode) { %>
    <div class="alert alert--error mt-4">
      <strong><%= deployment.failureCode %></strong>
      <% if (deployment.failureSummary) { %>
      <p class="text-sm mt-1"><%= deployment.failureSummary %></p>
      <% } %>
    </div>
    <% } %>
  </div>
</div>

<!-- Log viewer -->
<div class="card" id="log-card">
  <div class="card__header">
    <h2 class="card__title text-sm">Deployment Logs</h2>
    <% if (!['FAILED','CANCELLED','HEALTHY','ROLLED_BACK'].includes(deployment.status)) { %>
    <span class="badge badge--building text-xs" id="live-indicator">● Live</span>
    <% } %>
  </div>
  <div class="card__body p-0">
    <div class="log-viewer" id="log-output" aria-live="polite" aria-label="Deployment logs">
      <% if (events.length === 0 && ['QUEUED','VALIDATING'].includes(deployment.status)) { %>
      <div class="log-line log-line--info">Waiting for worker to pick up job…</div>
      <% } %>
      <% events.forEach(ev => { %>
      <div class="log-line log-line--<%= ev.level.toLowerCase() %>">
        <span class="log-line__stage"><%= ev.stage %></span>
        <span class="log-line__msg"><%= ev.messageRedacted %></span>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<% if (!['FAILED','CANCELLED','HEALTHY','ROLLED_BACK'].includes(deployment.status)) { %>
<script>
(function () {
  const output = document.getElementById('log-output');
  const indicator = document.getElementById('live-indicator');
  const streamUrl = '/projects/<%= project.slug %>/deployments/<%= deployment._id %>/logs';
  const eventStageToStatus = { VALIDATE: 'VALIDATING', BUILD: 'BUILDING', DEPLOY: 'DEPLOYING' };

  function updateTimeline(ev) {
    const statusKey = eventStageToStatus[ev.stage];
    if (!statusKey) return;

    const stage = document.querySelector(`[data-stage-key="${statusKey}"]`);
    if (!stage) return;

    stage.classList.remove('deployment-stage--pending', 'deployment-stage--complete');
    stage.classList.add('deployment-stage--active');

    const status = stage.querySelector('[data-stage-status]');
    const message = stage.querySelector('[data-stage-message]');
    const time = stage.querySelector('[data-stage-time]');
    if (status) status.textContent = 'In progress';
    if (message) message.textContent = ev.message || '';
    if (time && ev.timestamp) {
      time.textContent = new Date(ev.timestamp).toLocaleString('en-GB', {
        day: 'numeric',
        month: 'short',
        hour: '2-digit',
        minute: '2-digit',
      });
    }
  }

  function appendLog(ev) {
    const line = document.createElement('div');
    line.className = `log-line log-line--${(ev.level || 'info').toLowerCase()}`;
    const stage = document.createElement('span');
    stage.className = 'log-line__stage';
    stage.textContent = ev.stage || '';
    const message = document.createElement('span');
    message.className = 'log-line__msg';
    message.textContent = ev.message || '';
    line.append(stage, message);
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
    updateTimeline(ev);
  }

  const source = new EventSource(streamUrl);

  source.addEventListener('log', (e) => {
    try { appendLog(JSON.parse(e.data)); } catch {}
  });

  source.addEventListener('status', (e) => {
    try {
      const { status } = JSON.parse(e.data);
      if (indicator) { indicator.textContent = status; indicator.className = 'badge text-xs'; }
      source.close();
      // Reload page to show final state
      setTimeout(() => window.location.reload(), 1200);
    } catch {}
  });

  source.addEventListener('timeout', () => {
    if (indicator) indicator.textContent = 'Timed out';
    source.close();
  });

  source.onerror = () => {
    if (indicator) indicator.textContent = 'Disconnected';
    source.close();
  };
})();
</script>
<% } %>
