<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Project Detection</h1>
    <p class="page-header__subtitle text-muted text-sm">
      <a href="/projects/<%= project.slug %>" class="table-link">&larr; <%= project.name %></a>
    </p>
  </div>
</div>

<% if (!repo) { %>
<div class="card">
  <div class="card__body">
    <div class="empty-state">
      <p class="empty-state__title">No repository connected</p>
      <p class="empty-state__description">
        Connect a GitHub repository before running detection.
      </p>
      <ul class="empty-state__steps">
        <li>Connect the repository that contains this application.</li>
        <li>Choose the production branch HelloDeploy should watch.</li>
        <li>Run detection to identify runtime, build command, and port.</li>
      </ul>
      <div class="empty-state__actions">
        <a href="/projects/<%= project.slug %>/repository" class="button button--primary">
          Connect Repository
        </a>
      </div>
    </div>
  </div>
</div>
<% } else { %>

<!-- Current state -->
<div class="card">
  <div class="card__header">
    <span class="card__title">Runtime Configuration</span>
  </div>
  <div class="card__body">
    <dl class="detail-list">
      <dt>Detected runtime</dt>
      <dd>
        <% if (project.runtimeType) { %>
          <%- include('../../partials/status-badge', { status: project.runtimeType }) %>
        <% } else { %>
          <span class="text-muted text-sm">Not yet detected</span>
        <% } %>
      </dd>

      <dt>Repository</dt>
      <dd><code class="code-inline"><%= repo.fullName %></code></dd>
    </dl>
  </div>
</div>

<% const bc = project.buildConfiguration || {}; %>
<div class="card mt-6">
  <div class="card__header">
    <span class="card__title">Build &amp; Deploy Configuration</span>
  </div>
  <div class="card__body">
    <% if (membership.role === 'OWNER') { %>
    <p class="text-sm text-muted mb-4">
      These values override auto-detected settings. Leave a field blank to fall back to detection defaults.
    </p>
    <%
      const bcErrors = locals.bcErrors || {};
      const bcValues = locals.bcValues || null;
      const bcVal = (field, fallback) => (bcValues ? (bcValues[field] || '') : (fallback || ''));
    %>
    <%- include('../../partials/form-errors', { errors: bcErrors }) %>
    <form method="POST" action="/projects/<%= project.slug %>/build-configuration" novalidate>
      <%- include('../../partials/csrf-field') %>

      <div class="form-field form-field--floating">
        <label for="buildCommand" class="form-label">Build command</label>
        <input
          type="text"
          id="buildCommand"
          name="buildCommand"
          class="form-input<%= bcErrors.buildCommand ? ' form-input--error' : '' %>"
          value="<%= bcVal('buildCommand', bc.buildCommand) %>"
          maxlength="500"
          placeholder=" "
          <% if (bcErrors.buildCommand) { %>aria-describedby="buildCommand-error"<% } %>
        />
        <% if (bcErrors.buildCommand) { %>
        <span id="buildCommand-error" class="form-error" role="alert"><%= bcErrors.buildCommand %></span>
        <% } %>
      </div>

      <div class="form-field form-field--floating">
        <label for="startCommand" class="form-label">Start command</label>
        <input
          type="text"
          id="startCommand"
          name="startCommand"
          class="form-input<%= bcErrors.startCommand ? ' form-input--error' : '' %>"
          value="<%= bcVal('startCommand', bc.startCommand) %>"
          maxlength="500"
          placeholder=" "
          <% if (bcErrors.startCommand) { %>aria-describedby="startCommand-error"<% } %>
        />
        <% if (bcErrors.startCommand) { %>
        <span id="startCommand-error" class="form-error" role="alert"><%= bcErrors.startCommand %></span>
        <% } %>
      </div>

      <div class="form-field form-field--floating">
        <label for="outputDirectory" class="form-label">Output directory</label>
        <input
          type="text"
          id="outputDirectory"
          name="outputDirectory"
          class="form-input<%= bcErrors.outputDirectory ? ' form-input--error' : '' %>"
          value="<%= bcVal('outputDirectory', bc.outputDirectory) %>"
          maxlength="255"
          placeholder=" "
          <% if (bcErrors.outputDirectory) { %>aria-describedby="outputDirectory-error"<% } %>
        />
        <% if (bcErrors.outputDirectory) { %>
        <span id="outputDirectory-error" class="form-error" role="alert"><%= bcErrors.outputDirectory %></span>
        <% } %>
      </div>

      <div class="form-field form-field--floating">
        <label for="applicationPort" class="form-label">Application port</label>
        <input
          type="number"
          id="applicationPort"
          name="applicationPort"
          class="form-input<%= bcErrors.applicationPort ? ' form-input--error' : '' %>"
          value="<%= bcVal('applicationPort', bc.applicationPort) %>"
          min="1"
          max="65535"
          placeholder=" "
          <% if (bcErrors.applicationPort) { %>aria-describedby="applicationPort-error"<% } %>
        />
        <% if (bcErrors.applicationPort) { %>
        <span id="applicationPort-error" class="form-error" role="alert"><%= bcErrors.applicationPort %></span>
        <% } %>
      </div>

      <div class="form-field form-field--floating">
        <label for="healthCheckPath" class="form-label">Health check path</label>
        <input
          type="text"
          id="healthCheckPath"
          name="healthCheckPath"
          class="form-input<%= bcErrors.healthCheckPath ? ' form-input--error' : '' %>"
          value="<%= bcVal('healthCheckPath', bc.healthCheckPath || '/') %>"
          maxlength="255"
          placeholder=" "
          aria-describedby="<%= bcErrors.healthCheckPath ? 'healthCheckPath-error' : 'healthCheckPath-hint' %>"
        />
        <% if (bcErrors.healthCheckPath) { %>
        <span id="healthCheckPath-error" class="form-error" role="alert"><%= bcErrors.healthCheckPath %></span>
        <% } else { %>
        <span id="healthCheckPath-hint" class="form-hint">HTTP path HelloDeploy polls after each deploy to confirm the app is healthy.</span>
        <% } %>
      </div>

      <div class="form-actions mt-6">
        <button type="submit" class="button button--primary">Save Configuration</button>
      </div>
    </form>
    <% } else { %>
    <dl class="detail-list">
      <% if (bc.buildCommand) { %>
      <dt>Build command</dt>
      <dd><code class="code-inline"><%= bc.buildCommand %></code></dd>
      <% } %>
      <% if (bc.startCommand) { %>
      <dt>Start command</dt>
      <dd><code class="code-inline"><%= bc.startCommand %></code></dd>
      <% } %>
      <% if (bc.outputDirectory) { %>
      <dt>Output directory</dt>
      <dd><code class="code-inline"><%= bc.outputDirectory %></code></dd>
      <% } %>
      <% if (bc.applicationPort) { %>
      <dt>Application port</dt>
      <dd><code class="code-inline"><%= bc.applicationPort %></code></dd>
      <% } %>
      <dt>Health check path</dt>
      <dd><code class="code-inline"><%= bc.healthCheckPath || '/' %></code></dd>
    </dl>
    <% } %>
  </div>
</div>

<% const bf = project.buildFilters || {}; %>
<div class="card mt-6">
  <div class="card__header">
    <span class="card__title">Build Filters</span>
  </div>
  <div class="card__body">
    <% if (membership.role === 'OWNER') { %>
    <p class="text-sm text-muted mb-4">
      Control which pushes trigger a build in this repository. One glob pattern per line
      (e.g. <code class="code-inline">docs/**</code>, <code class="code-inline">*.md</code>).
      If a push only touches ignored or non-included paths, the build is skipped.
    </p>
    <%
      const bfErrors = locals.bfErrors || {};
      const bfValues = locals.bfValues || null;
    %>
    <%- include('../../partials/form-errors', { errors: bfErrors }) %>
    <form method="POST" action="/projects/<%= project.slug %>/build-filters" novalidate>
      <%- include('../../partials/csrf-field') %>

      <div class="form-field">
        <label for="includedPaths" class="form-label">Included paths</label>
        <textarea
          id="includedPaths"
          name="includedPaths"
          class="form-textarea<%= bfErrors.includedPaths ? ' form-input--error' : '' %>"
          rows="3"
          placeholder="src/**"
          aria-describedby="<%= bfErrors.includedPaths ? 'includedPaths-error' : 'includedPaths-hint' %>"
        ><%= bfValues ? (bfValues.includedPaths || '') : (bf.includedPaths || []).join('\n') %></textarea>
        <% if (bfErrors.includedPaths) { %>
        <span id="includedPaths-error" class="form-error" role="alert"><%= bfErrors.includedPaths %></span>
        <% } else { %>
        <span id="includedPaths-hint" class="form-hint">Leave blank to include all paths by default.</span>
        <% } %>
      </div>

      <div class="form-field">
        <label for="ignoredPaths" class="form-label">Ignored paths</label>
        <textarea
          id="ignoredPaths"
          name="ignoredPaths"
          class="form-textarea<%= bfErrors.ignoredPaths ? ' form-input--error' : '' %>"
          rows="3"
          placeholder="docs/**"
          <% if (bfErrors.ignoredPaths) { %>aria-describedby="ignoredPaths-error"<% } %>
        ><%= bfValues ? (bfValues.ignoredPaths || '') : (bf.ignoredPaths || []).join('\n') %></textarea>
        <% if (bfErrors.ignoredPaths) { %>
        <span id="ignoredPaths-error" class="form-error" role="alert"><%= bfErrors.ignoredPaths %></span>
        <% } %>
      </div>

      <div class="form-actions mt-6">
        <button type="submit" class="button button--primary">Save Build Filters</button>
      </div>
    </form>
    <% } else if ((bf.includedPaths && bf.includedPaths.length) || (bf.ignoredPaths && bf.ignoredPaths.length)) { %>
    <dl class="detail-list">
      <% if (bf.includedPaths && bf.includedPaths.length) { %>
      <dt>Included paths</dt>
      <dd><code class="code-inline"><%= bf.includedPaths.join(', ') %></code></dd>
      <% } %>
      <% if (bf.ignoredPaths && bf.ignoredPaths.length) { %>
      <dt>Ignored paths</dt>
      <dd><code class="code-inline"><%= bf.ignoredPaths.join(', ') %></code></dd>
      <% } %>
    </dl>
    <% } %>
  </div>
</div>

<!-- Detection result (shown immediately after running) -->
<% if (locals.detectionResult && detectionResult) { %>
<div class="card mt-6">
  <div class="card__header">
    <span class="card__title">Detection Results</span>
    <%- include('../../partials/status-badge', { status: detectionResult.isValid ? 'ACTIVE' : 'FAILED' }) %>
  </div>
  <div class="card__body">
    <% if (detectionResult.issues.length === 0) { %>
      <p class="text-sm text-success">No issues found. Your project looks good!</p>
    <% } else { %>
      <ul class="detection-issues">
        <% detectionResult.issues.forEach(issue => { %>
        <li class="detection-issue detection-issue--<%= issue.level.toLowerCase() %>">
          <strong class="detection-issue__level"><%= issue.level %></strong>
          <span class="detection-issue__message"><%= issue.message %></span>
        </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>
<% } %>

<% if (membership.role === 'OWNER') { %>
<div class="card mt-6">
  <div class="card__body">
    <p class="text-sm text-muted mb-4">
      Detection fetches key files from your repository and identifies your runtime, build command, and port configuration.
      Re-run any time after pushing changes.
    </p>
    <form method="POST" action="/projects/<%= project.slug %>/detection">
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--primary" data-pending-label="Running...">Run Detection</button>
    </form>
  </div>
</div>
<% } %>

<% } %>
