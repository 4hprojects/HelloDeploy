<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Project Settings</h1>
    <p class="page-header__subtitle text-muted text-sm"><%= project.name %></p>
  </div>
  <a href="/projects/<%= project.slug %>" class="button button--secondary">Back to Project</a>
</div>

<div class="project-settings-layout">
  <nav class="settings-section-nav" aria-label="Project settings sections">
    <p class="settings-section-nav__title">Settings</p>
    <ul class="settings-section-nav__list" role="list">
      <% settingsSections.forEach((section, index) => { %>
      <li>
        <a href="<%= section.href %>" class="settings-section-nav__link" data-settings-section-link <%= index === 0 ? 'aria-current="location"' : '' %>>
          <%= section.label %>
        </a>
      </li>
      <% }) %>
    </ul>
  </nav>

  <div class="settings-sections">
    <% const activeEdit = locals.activeSettingsEdit || null; %>
    <section class="card settings-section" id="general" tabindex="-1" aria-labelledby="general-title" data-settings-section>
      <div class="card__header"><h2 class="card__title" id="general-title">General</h2></div>
      <div class="card__body settings-group-list">
        <div class="settings-edit-group" data-settings-edit-group <%= activeEdit === 'general' ? 'data-editing' : '' %>>
          <div class="settings-field-row" data-settings-display <%= activeEdit === 'general' ? 'hidden' : '' %>>
            <div><span class="form-label">Project name</span><p class="form-hint">The display name shown throughout HelloDeploy.</p></div>
            <div class="settings-display-row"><strong class="settings-display-value"><%= project.name %></strong><button type="button" class="button button--secondary button--sm" data-settings-edit aria-label="Edit project name">Edit</button></div>
          </div>
          <form method="POST" action="/projects/<%= project.slug %>/update" novalidate data-settings-edit-form <%= activeEdit === 'general' ? '' : 'hidden' %>>
            <%- include('../../partials/csrf-field') %>
            <input type="hidden" name="returnTo" value="/projects/<%= project.slug %>/settings#general">
            <% const generalErrors = locals.settingsErrors || {}; %>
            <%- include('../../partials/form-errors', { errors: generalErrors }) %>
            <div class="settings-field-row">
              <div><label class="form-label" for="settings-name">Project name</label><p class="form-hint">The display name shown throughout HelloDeploy.</p></div>
              <div><input class="form-input<%= generalErrors.name ? ' form-input--error' : '' %>" id="settings-name" name="name" value="<%= locals.settingsValues?.name ?? project.name %>" maxlength="100" required <%= generalErrors.name ? 'aria-describedby="settings-name-error"' : '' %>><% if (generalErrors.name) { %><span class="form-error" id="settings-name-error" role="alert"><%= generalErrors.name %></span><% } %><div class="form-actions mt-2"><button type="button" class="button button--ghost button--sm" data-settings-cancel>Cancel</button><button class="button button--primary button--sm" type="submit" data-pending-label="Saving...">Save</button></div></div>
            </div>
          </form>
        </div>
        <div class="settings-field-row"><div><span class="form-label">Slug</span><p class="form-hint">Stable routing identifier; changing it is not currently supported.</p></div><code class="code-inline"><%= project.slug %></code></div>
        <div class="settings-field-row"><div><span class="form-label">Project status</span><p class="form-hint">Lifecycle state controlled by review and project operations.</p></div><%- include('../../partials/status-badge', { status: project.status }) %></div>
        <div class="settings-field-row"><div><span class="form-label">Effective resources</span><p class="form-hint">Read-only limits resolved from platform defaults and administrator overrides.</p></div><dl class="settings-inline-details"><div><dt>CPU</dt><dd><%= quota.cpuCores %> core</dd></div><div><dt>Memory</dt><dd><%= quota.memoryMb %> MB</dd></div><div><dt>Storage</dt><dd><%= quota.storageMb %> MB</dd></div><div><dt>Build timeout</dt><dd><%= quota.buildTimeoutSeconds %> seconds</dd></div></dl></div>
      </div>
    </section>

    <section class="card settings-section" id="source-build" tabindex="-1" aria-labelledby="source-build-title" data-settings-section>
      <div class="card__header page-header--actions"><h2 class="card__title" id="source-build-title">Source &amp; Build</h2><div class="button-group button-group--sm"><a href="/projects/<%= project.slug %>/repository" class="button button--secondary button--sm">Manage repository</a><a href="/projects/<%= project.slug %>/detection" class="button button--secondary button--sm">Run detection</a></div></div>
      <div class="card__body settings-group-list">
        <div class="settings-field-row"><div><span class="form-label">Repository</span><p class="form-hint">GitHub source used for detection and deployment.</p></div><% if (repository) { %><div><code class="code-inline"><%= repository.fullName %></code><p class="text-xs text-muted mt-1">Production branch: <code class="code-inline"><%= project.productionBranch %></code></p></div><% } else { %><span class="text-muted text-sm">Not connected</span><% } %></div>
        <div class="settings-field-row"><div><span class="form-label">Detected runtime</span><p class="form-hint">Re-run detection after material repository changes.</p></div><% if (project.runtimeType) { %><%- include('../../partials/status-badge', { status: project.runtimeType }) %><% } else { %><span class="text-muted text-sm">Not detected</span><% } %></div>
        <% const bc = project.buildConfiguration || {}; const bcErrors = locals.bcErrors || {}; const bcValues = locals.bcValues || null; const bcVal = (field, fallback) => bcValues ? (bcValues[field] ?? '') : (fallback ?? ''); %>
        <div class="settings-edit-group" data-settings-edit-group <%= activeEdit === 'build-configuration' ? 'data-editing' : '' %>>
          <div class="settings-field-row" data-settings-display <%= activeEdit === 'build-configuration' ? 'hidden' : '' %>><div><span class="form-label">Build configuration</span><p class="form-hint">Commands, output directory, and application port.</p></div><div class="settings-display-row"><span class="settings-display-value text-sm text-muted"><%= bc.buildCommand || 'Detected defaults' %></span><button type="button" class="button button--secondary button--sm" data-settings-edit aria-label="Edit build configuration">Edit</button></div></div>
        <form method="POST" action="/projects/<%= project.slug %>/build-configuration" novalidate data-settings-edit-form <%= activeEdit === 'build-configuration' ? '' : 'hidden' %>>
          <%- include('../../partials/csrf-field') %>
          <input type="hidden" name="returnTo" value="/projects/<%= project.slug %>/settings#source-build">
          <%- include('../../partials/form-errors', { errors: bcErrors }) %>
          <div class="settings-form-grid">
            <div class="form-group"><label class="form-label" for="settings-build-command">Build command</label><input class="form-input<%= bcErrors.buildCommand ? ' form-input--error' : '' %>" id="settings-build-command" name="buildCommand" value="<%= bcVal('buildCommand', bc.buildCommand) %>" maxlength="500"><% if (bcErrors.buildCommand) { %><span class="form-error" role="alert"><%= bcErrors.buildCommand %></span><% } %></div>
            <div class="form-group"><label class="form-label" for="settings-start-command">Start command</label><input class="form-input<%= bcErrors.startCommand ? ' form-input--error' : '' %>" id="settings-start-command" name="startCommand" value="<%= bcVal('startCommand', bc.startCommand) %>" maxlength="500"><% if (bcErrors.startCommand) { %><span class="form-error" role="alert"><%= bcErrors.startCommand %></span><% } %></div>
            <div class="form-group"><label class="form-label" for="settings-output-directory">Output directory</label><input class="form-input<%= bcErrors.outputDirectory ? ' form-input--error' : '' %>" id="settings-output-directory" name="outputDirectory" value="<%= bcVal('outputDirectory', bc.outputDirectory) %>" maxlength="255"><% if (bcErrors.outputDirectory) { %><span class="form-error" role="alert"><%= bcErrors.outputDirectory %></span><% } %></div>
            <div class="form-group"><label class="form-label" for="settings-application-port">Application port</label><input class="form-input<%= bcErrors.applicationPort ? ' form-input--error' : '' %>" type="number" id="settings-application-port" name="applicationPort" value="<%= bcVal('applicationPort', bc.applicationPort) %>" min="1" max="65535" <%= ['STATIC', 'REACT', 'VUE'].includes(project.runtimeType) ? 'disabled' : '' %>><% if (bcErrors.applicationPort) { %><span class="form-error" role="alert"><%= bcErrors.applicationPort %></span><% } %></div>
            <input type="hidden" name="healthCheckPath" value="<%= bc.healthCheckPath || '/' %>">
          </div>
          <div class="form-actions mt-4"><button type="button" class="button button--ghost" data-settings-cancel>Cancel</button><button type="submit" class="button button--primary" data-pending-label="Saving build settings...">Save build settings</button></div>
        </form>
        </div>
        <% const bf = project.buildFilters || {}; const bfErrors = locals.bfErrors || {}; const bfValues = locals.bfValues || null; %>
        <div class="settings-edit-group" data-settings-edit-group <%= activeEdit === 'build-filters' ? 'data-editing' : '' %>>
          <div class="settings-field-row" data-settings-display <%= activeEdit === 'build-filters' ? 'hidden' : '' %>><div><span class="form-label">Build filters</span><p class="form-hint">Included and ignored paths for automatic builds.</p></div><div class="settings-display-row"><span class="settings-display-value text-sm text-muted"><%= (bf.includedPaths || []).length %> included, <%= (bf.ignoredPaths || []).length %> ignored</span><button type="button" class="button button--secondary button--sm" data-settings-edit aria-label="Edit build filters">Edit</button></div></div>
        <form method="POST" action="/projects/<%= project.slug %>/build-filters" novalidate data-settings-edit-form <%= activeEdit === 'build-filters' ? '' : 'hidden' %>>
          <%- include('../../partials/csrf-field') %>
          <input type="hidden" name="returnTo" value="/projects/<%= project.slug %>/settings#source-build">
          <%- include('../../partials/form-errors', { errors: bfErrors }) %>
          <div class="settings-form-grid">
            <div class="form-group"><label class="form-label" for="settings-included-paths">Included paths</label><textarea class="form-textarea<%= bfErrors.includedPaths ? ' form-input--error' : '' %>" id="settings-included-paths" name="includedPaths" rows="3" placeholder="src/**"><%= bfValues ? (bfValues.includedPaths || '') : (bf.includedPaths || []).join('\n') %></textarea><% if (bfErrors.includedPaths) { %><span class="form-error" role="alert"><%= bfErrors.includedPaths %></span><% } else { %><p class="form-hint">One glob per line; blank includes all paths.</p><% } %></div>
            <div class="form-group"><label class="form-label" for="settings-ignored-paths">Ignored paths</label><textarea class="form-textarea<%= bfErrors.ignoredPaths ? ' form-input--error' : '' %>" id="settings-ignored-paths" name="ignoredPaths" rows="3" placeholder="docs/**"><%= bfValues ? (bfValues.ignoredPaths || '') : (bf.ignoredPaths || []).join('\n') %></textarea><% if (bfErrors.ignoredPaths) { %><span class="form-error" role="alert"><%= bfErrors.ignoredPaths %></span><% } else { %><p class="form-hint">Matching changes do not trigger automatic builds.</p><% } %></div>
          </div>
          <div class="form-actions mt-4"><button type="button" class="button button--ghost" data-settings-cancel>Cancel</button><button type="submit" class="button button--primary" data-pending-label="Saving filters...">Save build filters</button></div>
        </form>
        </div>
      </div>
    </section>

    <section class="card settings-section" id="deployment" tabindex="-1" aria-labelledby="deployment-title" data-settings-section>
      <div class="card__header"><h2 class="card__title" id="deployment-title">Deployment</h2></div>
      <div class="card__body settings-group-list">
        <div class="settings-edit-group" data-settings-edit-group><div class="settings-field-row" data-settings-display><div><span class="form-label">Deployment mode</span><p class="form-hint">Choose how production deployments are triggered.</p></div><div class="settings-display-row"><strong><%= project.deploymentMode === 'APPROVAL_REQUIRED' ? 'Approval required' : project.deploymentMode.charAt(0) + project.deploymentMode.slice(1).toLowerCase() %></strong><button type="button" class="button button--secondary button--sm" data-settings-edit aria-label="Edit deployment mode">Edit</button></div></div><form method="POST" action="/projects/<%= project.slug %>/deployment-mode" data-settings-edit-form hidden><%- include('../../partials/csrf-field') %><input type="hidden" name="returnTo" value="/projects/<%= project.slug %>/settings#deployment"><div class="settings-field-row"><div><label class="form-label" for="settings-deployment-mode">Deployment mode</label><p class="form-hint">Automatic mode requires an approved active project.</p></div><div><select class="form-select" id="settings-deployment-mode" name="deploymentMode"><% ['MANUAL', 'AUTOMATIC', 'APPROVAL_REQUIRED'].forEach(mode => { %><option value="<%= mode %>" <%= project.deploymentMode === mode ? 'selected' : '' %>><%= mode === 'APPROVAL_REQUIRED' ? 'Approval required' : mode.charAt(0) + mode.slice(1).toLowerCase() %></option><% }) %></select><div class="form-actions mt-2"><button type="button" class="button button--ghost button--sm" data-settings-cancel>Cancel</button><button type="submit" class="button button--primary button--sm" data-pending-label="Saving...">Save</button></div></div></div></form></div>
        <div class="settings-field-row"><div><span class="form-label">Deploy hook</span><p class="form-hint">Secret URL for trusted CI systems. Raw URLs are shown only when generated.</p></div><div><p class="text-sm <%= hasDeployHook ? 'text-success' : 'text-muted' %> mb-2"><%= hasDeployHook ? 'Configured' : 'Not configured' %></p><div class="button-group"><form method="POST" action="/projects/<%= project.slug %>/deploy-hook/generate"><%- include('../../partials/csrf-field') %><button type="submit" class="button button--secondary button--sm" data-pending-label="Generating..."><%= hasDeployHook ? 'Regenerate' : 'Generate' %></button></form><% if (hasDeployHook) { %><form method="POST" action="/projects/<%= project.slug %>/deploy-hook/revoke" data-confirm="Revoke the deploy hook? The current URL will stop working immediately." data-confirm-title="Revoke deploy hook" data-confirm-accept-label="Revoke" data-confirm-pending-label="Revoking..." data-confirm-variant="danger"><%- include('../../partials/csrf-field') %><button type="submit" class="button button--danger button--sm">Revoke</button></form><% } %></div></div></div>
      </div>
    </section>

    <section class="card settings-section" id="custom-domains" tabindex="-1" aria-labelledby="custom-domains-title" data-settings-section>
      <div class="card__header page-header--actions"><div><h2 class="card__title" id="custom-domains-title">Custom Domains</h2><p class="text-sm text-muted mt-1"><%= domains.length %> of <%= quota.maxCustomDomains %> configured</p></div><a href="/projects/<%= project.slug %>/domains" class="button button--secondary button--sm">Open DNS guidance</a></div>
      <div class="card__body settings-group-list">
        <form method="POST" action="/projects/<%= project.slug %>/domains"><%- include('../../partials/csrf-field') %><div class="settings-field-row"><div><label class="form-label" for="settings-domain">Add domain</label><p class="form-hint">A DNS verification token will be shown on the Domains page.</p></div><div class="settings-field-row__control"><input class="form-input" id="settings-domain" name="hostname" placeholder="app.example.com" required autocomplete="off"><button type="submit" class="button button--primary button--sm" data-pending-label="Adding...">Add</button></div></div></form>
        <% if (domains.length) { %><div class="table-wrapper table-responsive table-responsive--flush"><table class="table table--responsive"><thead><tr><th scope="col">Hostname</th><th scope="col">Status</th><th scope="col"><span class="sr-only">Actions</span></th></tr></thead><tbody><% domains.forEach(domain => { %><tr><td data-label="Hostname"><code class="code-inline"><%= domain.hostnameNormalized %></code></td><td data-label="Status"><%- include('../../partials/status-badge', { status: domain.status }) %></td><td class="text-right" data-label="Actions"><div class="button-group button-group--sm"><% if (domain.status === 'PENDING_VERIFICATION') { %><form method="POST" action="/projects/<%= project.slug %>/domains/<%= domain._id %>/verify"><%- include('../../partials/csrf-field') %><button type="submit" class="button button--secondary button--sm" data-pending-label="Checking...">Check verification</button></form><% } %><form method="POST" action="/projects/<%= project.slug %>/domains/<%= domain._id %>/remove" data-confirm="Remove <%= domain.hostnameNormalized %> from this project?" data-confirm-title="Remove domain" data-confirm-accept-label="Remove Domain" data-confirm-pending-label="Removing..." data-confirm-variant="danger"><%- include('../../partials/csrf-field') %><button type="submit" class="button button--danger button--sm">Remove</button></form></div></td></tr><% }) %></tbody></table></div><% } else { %><p class="text-sm text-muted">No custom domains configured.</p><% } %>
      </div>
    </section>

    <section class="card settings-section" id="notifications" tabindex="-1" aria-labelledby="notifications-title" data-settings-section>
      <div class="card__header"><h2 class="card__title" id="notifications-title">Notifications</h2></div>
      <div class="card__body"><div class="settings-edit-group" data-settings-edit-group><div class="settings-field-row" data-settings-display><div><span class="form-label">Deployment email</span><p class="form-hint">Choose which deployment outcomes email the project owner.</p></div><div class="settings-display-row"><strong><%= (project.notificationPreference || 'ALL') === 'ALL' ? 'All outcomes' : project.notificationPreference === 'FAILURE_ONLY' ? 'Failures only' : 'None' %></strong><button type="button" class="button button--secondary button--sm" data-settings-edit aria-label="Edit deployment notifications">Edit</button></div></div><form method="POST" action="/projects/<%= project.slug %>/notification-preference" data-settings-edit-form hidden><%- include('../../partials/csrf-field') %><input type="hidden" name="returnTo" value="/projects/<%= project.slug %>/settings#notifications"><div class="settings-field-row"><div><label class="form-label" for="settings-notifications">Deployment email</label><p class="form-hint">Messages are sent to the project owner.</p></div><div><select class="form-select" id="settings-notifications" name="notificationPreference"><option value="ALL" <%= (project.notificationPreference || 'ALL') === 'ALL' ? 'selected' : '' %>>All outcomes</option><option value="FAILURE_ONLY" <%= project.notificationPreference === 'FAILURE_ONLY' ? 'selected' : '' %>>Failures only</option><option value="NONE" <%= project.notificationPreference === 'NONE' ? 'selected' : '' %>>None</option></select><div class="form-actions mt-2"><button type="button" class="button button--ghost button--sm" data-settings-cancel>Cancel</button><button type="submit" class="button button--primary button--sm" data-pending-label="Saving...">Save</button></div></div></div></form></div></div>
    </section>

    <section class="card settings-section" id="health-maintenance" tabindex="-1" aria-labelledby="health-maintenance-title" data-settings-section>
      <div class="card__header"><h2 class="card__title" id="health-maintenance-title">Health &amp; Maintenance</h2></div>
      <div class="card__body settings-group-list">
        <div class="settings-edit-group" data-settings-edit-group <%= activeEdit === 'health-check' ? 'data-editing' : '' %>><div class="settings-field-row" data-settings-display <%= activeEdit === 'health-check' ? 'hidden' : '' %>><div><span class="form-label">Health-check path</span><p class="form-hint">HTTP path polled before a candidate release becomes active.</p></div><div class="settings-display-row"><code class="code-inline"><%= bc.healthCheckPath || '/' %></code><button type="button" class="button button--secondary button--sm" data-settings-edit aria-label="Edit health-check path">Edit</button></div></div><form method="POST" action="/projects/<%= project.slug %>/build-configuration" novalidate data-settings-edit-form <%= activeEdit === 'health-check' ? '' : 'hidden' %>><%- include('../../partials/csrf-field') %><input type="hidden" name="returnTo" value="/projects/<%= project.slug %>/settings#health-maintenance"><input type="hidden" name="buildCommand" value="<%= bcVal('buildCommand', bc.buildCommand) %>"><input type="hidden" name="startCommand" value="<%= bcVal('startCommand', bc.startCommand) %>"><input type="hidden" name="outputDirectory" value="<%= bcVal('outputDirectory', bc.outputDirectory) %>"><input type="hidden" name="applicationPort" value="<%= bcVal('applicationPort', bc.applicationPort) %>"><%- include('../../partials/form-errors', { errors: bcErrors }) %><div class="settings-field-row"><div><label class="form-label" for="settings-health-path">Health-check path</label><p class="form-hint">Must begin with a slash.</p></div><div><input class="form-input<%= bcErrors.healthCheckPath ? ' form-input--error' : '' %>" id="settings-health-path" name="healthCheckPath" value="<%= bcVal('healthCheckPath', bc.healthCheckPath || '/') %>" maxlength="255" required><% if (bcErrors.healthCheckPath) { %><span class="form-error" role="alert"><%= bcErrors.healthCheckPath %></span><% } %><div class="form-actions mt-2"><button type="button" class="button button--ghost button--sm" data-settings-cancel>Cancel</button><button type="submit" class="button button--primary button--sm" data-pending-label="Saving...">Save</button></div></div></div></form></div>
        <div class="settings-field-row"><div><span class="form-label">Maintenance mode</span><p class="form-hint">Temporarily replace public traffic with the built-in maintenance page.</p></div><div><p class="text-sm mb-2"><%- include('../../partials/status-badge', { status: project.maintenanceMode?.enabled ? 'SUSPENDED' : 'ACTIVE' }) %></p><% if (project.maintenanceMode?.enabled) { %><form method="POST" action="/projects/<%= project.slug %>/maintenance/disable" data-confirm="Disable maintenance mode and resume traffic?" data-confirm-title="Disable maintenance" data-confirm-accept-label="Disable Maintenance" data-confirm-pending-label="Disabling..." data-confirm-variant="success"><%- include('../../partials/csrf-field') %><button type="submit" class="button button--success button--sm">Disable maintenance</button></form><% } else { %><form method="POST" action="/projects/<%= project.slug %>/maintenance/enable" data-confirm="Enable maintenance mode? Visitors will see a maintenance page instead of the app." data-confirm-title="Enable maintenance" data-confirm-accept-label="Enable Maintenance" data-confirm-pending-label="Enabling..." data-confirm-variant="warning"><%- include('../../partials/csrf-field') %><div class="form-group mb-2"><label class="form-label" for="settings-maintenance-message">Message (optional)</label><input class="form-input" id="settings-maintenance-message" name="message" maxlength="200"></div><button type="submit" class="button button--warning button--sm">Enable maintenance</button></form><% } %></div></div>
      </div>
    </section>

    <section class="card card--danger settings-section" id="danger-zone" tabindex="-1" aria-labelledby="danger-zone-title" data-settings-section>
      <div class="card__header"><h2 class="card__title" id="danger-zone-title">Danger Zone</h2></div>
      <div class="card__body settings-group-list">
        <% if (project.status !== 'ARCHIVED') { %><div class="danger-action"><div><strong>Archive project</strong><p class="text-sm text-muted">Stops the application and makes the project read-only.</p></div><form method="POST" action="/projects/<%= project.slug %>/archive" data-confirm="Archive <%= project.name %>? The application will be stopped and the project will become read-only." data-confirm-title="Archive project" data-confirm-accept-label="Archive Project" data-confirm-pending-label="Archiving..." data-confirm-variant="danger"><%- include('../../partials/csrf-field') %><button type="submit" class="button button--danger button--sm">Archive</button></form></div><% } %>
        <div class="danger-action"><div><strong>Delete project permanently</strong><p class="text-sm text-muted">Deletes deployments, domains, secrets, and membership records. This cannot be undone.</p></div><form method="POST" action="/projects/<%= project.slug %>/delete" data-confirm="Permanently delete <%= project.name %> and all project data?" data-confirm-title="Delete project" data-confirm-accept-label="Delete Project" data-confirm-pending-label="Deleting..." data-confirm-variant="danger"><%- include('../../partials/csrf-field') %><label class="form-label" for="settings-confirm-slug">Type <code class="code-inline"><%= project.slug %></code> to confirm</label><div class="settings-field-row__control"><input class="form-input" id="settings-confirm-slug" name="confirmSlug" autocomplete="off" required><button type="submit" class="button button--danger button--sm">Delete</button></div></form></div>
      </div>
    </section>
  </div>
</div>
