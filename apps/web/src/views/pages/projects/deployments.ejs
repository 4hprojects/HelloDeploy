<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Deployments</h1>
    <p class="page-header__subtitle text-muted text-sm">
      <a href="/projects/<%= project.slug %>" class="table-link">&larr; <%= project.name %></a>
    </p>
  </div>
  <% const canDeploy = membership.role === 'OWNER' || membership.role === 'MAINTAINER'; %>
  <% if (canDeploy) { %>
  <div class="button-group">
    <form method="POST" action="/projects/<%= project.slug %>/deployments">
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--primary" data-pending-label="Deploying..." data-tooltip="Deploy the latest commit from the production branch.">Deploy Latest</button>
    </form>
    <form method="POST" action="/projects/<%= project.slug %>/deployments">
      <%- include('../../partials/csrf-field') %>
      <input type="hidden" name="noCache" value="true">
      <button type="submit" class="button button--secondary button--sm" data-pending-label="Deploying..." data-tooltip="Rebuild without using cached build layers.">Deploy (no cache)</button>
    </form>
  </div>
  <% } %>
</div>

<% if (canDeploy) { %>
<div class="card mb-4">
  <div class="card__header">
    <h2 class="card__title text-sm">Deploy a Specific Commit</h2>
  </div>
  <div class="card__body">
    <p class="text-sm text-muted mb-4">
      Build and deploy an exact commit instead of the latest one on the production branch.
      Paste the full 40-character SHA.
    </p>
    <form method="POST" action="/projects/<%= project.slug %>/deployments" class="form-inline" novalidate>
      <%- include('../../partials/csrf-field') %>
      <div class="form-field">
        <label for="commitSha" class="form-label sr-only">Commit SHA</label>
        <input
          type="text"
          id="commitSha"
          name="commitSha"
          class="form-input<%= locals.commitShaError ? ' form-input--error' : '' %>"
          value="<%= locals.commitShaValue || '' %>"
          placeholder="e.g. 4b825dc642cb6eb9a060e54bf8d69288fbee4904"
          pattern="[0-9a-fA-F]{40}"
          maxlength="40"
          spellcheck="false"
          autocomplete="off"
          <% if (locals.commitShaError) { %>aria-describedby="commitSha-error"<% } %>
        />
        <% if (locals.commitShaError) { %>
        <span id="commitSha-error" class="form-error" role="alert"><%= commitShaError %></span>
        <% } %>
      </div>
      <button type="submit" class="button button--secondary" data-pending-label="Deploying...">Deploy Commit</button>
    </form>
  </div>
</div>
<% } %>

<% if (rollbackTargets && rollbackTargets.length > 0 && canDeploy) { %>
<div class="card mb-4">
  <div class="card__header">
    <h2 class="card__title text-sm">Rollback</h2>
  </div>
  <div class="card__body">
    <form method="POST" action="/projects/<%= project.slug %>/rollback" class="form-inline"
          data-confirm="Roll back production traffic to the selected retained healthy deployment?"
          data-confirm-title="Roll back deployment"
          data-confirm-accept-label="Roll Back"
          data-confirm-pending-label="Rolling back..."
          data-confirm-variant="warning">
      <%- include('../../partials/csrf-field') %>
      <label for="targetDeploymentId" class="form-label text-sm">Roll back to</label>
      <select name="targetDeploymentId" id="targetDeploymentId" class="form-select form-select--sm">
        <% rollbackTargets.forEach(d => { %>
        <option value="<%= d._id %>">
          #<%= d.sequenceNumber %> — <%= d.commitSha ? d.commitSha.slice(0, 7) : '—' %>
          <% if (d.commitMessage) { %> – <%= d.commitMessage.slice(0, 40) %><% } %>
        </option>
        <% }) %>
      </select>
      <button type="submit" class="button button--warning button--sm" data-tooltip="Restore the selected retained healthy deployment.">Roll Back</button>
    </form>
  </div>
</div>
<% } %>

<% if (deployments.length === 0) { %>
<div class="card">
  <div class="card__body">
    <div class="empty-state">
      <p class="empty-state__title">No deployments yet</p>
      <p class="empty-state__description">
        Complete the setup path before the first deployment.
      </p>
      <ul class="empty-state__steps">
        <li>Connect a repository and select the production branch.</li>
        <li>Run detection so HelloDeploy knows how to build the app.</li>
        <li>Add required environment secrets, then deploy the latest commit.</li>
      </ul>
      <div class="empty-state__actions">
        <a href="/projects/<%= project.slug %>/repository" class="button button--secondary">Repository</a>
        <a href="/projects/<%= project.slug %>/detection" class="button button--secondary">Detection</a>
        <% if (canDeploy) { %>
        <form method="POST" action="/projects/<%= project.slug %>/deployments">
          <%- include('../../partials/csrf-field') %>
          <button type="submit" class="button button--primary" data-pending-label="Deploying...">Deploy Latest</button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="card__body">
    <div class="table-wrapper table-responsive table-responsive--flush">
    <table class="table table--responsive">
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">Status</th>
          <th scope="col">Commit</th>
          <th scope="col">Trigger</th>
          <th scope="col">Started</th>
          <th scope="col">Duration</th>
          <th scope="col"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody>
        <% deployments.forEach(d => { %>
        <tr>
          <td class="text-muted text-sm" data-label="#">
            <a href="/projects/<%= project.slug %>/deployments/<%= d._id %>" class="table-link">
              #<%= d.sequenceNumber %>
            </a>
          </td>
          <td data-label="Status"><%- include('../../partials/status-badge', { status: d.status }) %></td>
          <td data-label="Commit">
            <code class="code-inline"><%= d.commitSha ? d.commitSha.slice(0, 7) : '—' %></code>
            <% if (d.commitMessage) { %>
              <span class="text-muted text-sm d-block"><%= d.commitMessage.slice(0, 60) %></span>
            <% } %>
          </td>
          <td class="text-muted text-sm" data-label="Trigger"><%= d.triggerType %></td>
          <td class="text-muted text-sm" data-label="Started">
            <% if (d.startedAt) { %>
              <%= new Date(d.startedAt).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
            <% } else { %> — <% } %>
          </td>
          <td class="text-muted text-sm" data-label="Duration">
            <% if (d.startedAt && d.completedAt) { %>
              <% const secs = Math.round((new Date(d.completedAt) - new Date(d.startedAt)) / 1000); %>
              <%= secs < 60 ? `${secs}s` : `${Math.floor(secs/60)}m ${secs%60}s` %>
            <% } else if (d.startedAt) { %>
              <span class="text-muted">Running…</span>
            <% } else { %> — <% } %>
          </td>
          <td class="text-right" data-label="Actions">
            <div class="button-group button-group--sm">
              <a href="/projects/<%= project.slug %>/deployments/<%= d._id %>" class="button button--ghost button--sm" data-tooltip="Open build and runtime logs for this deployment.">Logs</a>
              <% if (['QUEUED','VALIDATING','BUILDING','DEPLOYING'].includes(d.status) && canDeploy) { %>
              <form method="POST"
                    action="/projects/<%= project.slug %>/deployments/<%= d._id %>/cancel"
                    data-confirm="Cancel this deployment before it completes?"
                    data-confirm-title="Cancel deployment"
                    data-confirm-accept-label="Cancel Deployment"
                    data-confirm-pending-label="Cancelling..."
                    data-confirm-variant="danger">
                <%- include('../../partials/csrf-field') %>
                <button type="submit" class="button button--danger button--sm" data-tooltip="Cancel this deployment before it completes.">Cancel</button>
              </form>
              <% } %>
              <% if (['FAILED','CANCELLED'].includes(d.status) && canDeploy) { %>
              <form method="POST" action="/projects/<%= project.slug %>/deployments/<%= d._id %>/retry">
                <%- include('../../partials/csrf-field') %>
                <button type="submit" class="button button--secondary button--sm" data-pending-label="Retrying..." data-tooltip="Queue another deployment attempt for this commit.">Retry</button>
              </form>
              <% } %>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>
</div>

<% if (totalPages > 1) { %>
<div class="pagination mt-4">
  <% if (page > 1) { %>
  <a href="?page=<%= page - 1 %>" class="button button--ghost button--sm">Previous</a>
  <% } %>
  <span class="pagination__info text-sm text-muted">Page <%= page %> of <%= totalPages %> (<%= total %> deployments)</span>
  <% if (page < totalPages) { %>
  <a href="?page=<%= page + 1 %>" class="button button--ghost button--sm">Next</a>
  <% } %>
</div>
<% } %>
<% } %>
