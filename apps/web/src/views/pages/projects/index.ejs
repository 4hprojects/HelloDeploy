<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Projects</h1>
  </div>
  <a href="/projects/new" class="button button--primary">New Project</a>
</div>

<% if (projects.length === 0) { %>
<div class="empty-state">
  <div class="empty-state__icon" aria-hidden="true">◫</div>
  <h2 class="empty-state__title">No projects yet</h2>
  <p class="empty-state__description">Create your first project and get your app running.</p>
  <a href="/projects/new" class="button button--primary">Create Project</a>
</div>
<% } else { %>
<div class="table-wrapper">
  <table class="table">
    <thead>
      <tr>
        <th scope="col">Name</th>
        <th scope="col">Status</th>
        <th scope="col">Role</th>
        <th scope="col">Created</th>
        <th scope="col"><span class="sr-only">Actions</span></th>
      </tr>
    </thead>
    <tbody>
      <% projects.forEach(({ project, role }) => { %>
      <tr>
        <td>
          <a href="/projects/<%= project.slug %>" class="table-link"><strong><%= project.name %></strong></a>
          <span class="text-muted text-xs d-block"><%= project.slug %></span>
        </td>
        <td><%- include('../../partials/status-badge', { status: project.status }) %></td>
        <td><span class="role-pill"><%= role %></span></td>
        <td class="text-muted text-sm"><%= new Date(project.createdAt).toLocaleDateString('en-GB') %></td>
        <td class="text-right">
          <a href="/projects/<%= project.slug %>" class="button button--ghost button--sm">Open</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
