<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Environment Variables</h1>
    <p class="page-header__subtitle text-muted text-sm">
      <a href="/projects/<%= project.slug %>" class="table-link">&larr; <%= project.name %></a>
    </p>
  </div>
</div>

<div class="card">
  <div class="card__header">
    <span class="card__title">Add Secret</span>
  </div>
  <div class="card__body">
    <% const formErrors = locals.errors || {}; %>
    <%- include('../../partials/form-errors', { errors: formErrors }) %>
    <form method="POST" action="/projects/<%= project.slug %>/environment">
      <%- include('../../partials/csrf-field') %>
      <div class="form-row">
        <div class="form-group form-group--floating">
          <label class="form-label" for="name">Name</label>
          <input
            type="text"
            class="form-input text-uppercase<%= formErrors.name ? ' form-input--error' : '' %>"
            id="name"
            name="name"
            placeholder="DATABASE_URL"
            value="<%= locals.values?.name ?? '' %>"
            pattern="[A-Z_][A-Z0-9_]*"
            maxlength="128"
            required
            autocomplete="off"
            aria-describedby="<%= formErrors.name ? 'name-error' : 'name-hint' %>"
          >
          <% if (formErrors.name) { %>
          <p class="form-error" id="name-error" role="alert"><%= formErrors.name %></p>
          <% } else { %>
          <p class="form-hint text-xs text-muted" id="name-hint">Uppercase letters, digits, underscores. Example: DATABASE_URL</p>
          <% } %>
        </div>
        <div class="form-group form-group--floating">
          <label class="form-label" for="value">Value</label>
          <input
            type="password"
            class="form-input<%= formErrors.value ? ' form-input--error' : '' %>"
            id="value"
            name="value"
            placeholder="•••••••••••••••"
            autocomplete="new-password"
            required
            aria-describedby="<%= formErrors.value ? 'value-error' : 'value-hint' %>"
          >
          <% if (formErrors.value) { %>
          <p class="form-error" id="value-error" role="alert"><%= formErrors.value %></p>
          <% } else { %>
          <p class="form-hint text-xs text-muted" id="value-hint">Value is encrypted immediately — it cannot be retrieved after saving.</p>
          <% } %>
        </div>
      </div>
      <div class="form-actions">
        <button type="submit" class="button button--primary" data-pending-label="Saving...">Save Secret</button>
      </div>
    </form>
  </div>
</div>

<div class="card mt-6">
  <div class="card__header">
    <span class="card__title">Stored Secrets</span>
    <span class="text-muted text-sm"><%= secrets.length %> secret<%= secrets.length === 1 ? '' : 's' %></span>
  </div>
  <div class="card__body">
    <% if (secrets.length === 0) { %>
      <div class="empty-state empty-state--compact">
        <p class="empty-state__title">No secrets yet</p>
        <p class="empty-state__description">Add only the variables your app needs at runtime.</p>
        <ul class="empty-state__steps">
          <li>Use uppercase names such as DATABASE_URL or API_KEY.</li>
          <li>Paste the value once; it is encrypted immediately.</li>
          <li>Redeploy after changing secrets so containers receive the new values.</li>
        </ul>
      </div>
    <% } else { %>
      <div class="table-wrapper table-responsive table-responsive--flush">
      <table class="table table--responsive">
        <thead>
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Value</th>
            <th scope="col">Last updated</th>
            <th scope="col"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody>
          <% secrets.forEach(secret => { %>
          <tr>
            <td data-label="Name"><code class="code-inline"><%= secret.name %></code></td>
            <td class="text-muted text-sm" data-label="Value">••••••••</td>
            <td class="text-muted text-sm" data-label="Last updated">
              <%= new Date(secret.updatedAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
            </td>
            <td class="text-right" data-label="Actions">
              <form method="POST"
                    action="/projects/<%= project.slug %>/environment/<%= secret.name %>/delete"
                    data-confirm="Delete <%= secret.name %>? This cannot be undone and the value cannot be recovered."
                    data-confirm-title="Delete secret"
                    data-confirm-accept-label="Delete Secret"
                    data-confirm-pending-label="Deleting..."
                    data-confirm-variant="danger">
                <%- include('../../partials/csrf-field') %>
                <button type="submit" class="button button--danger button--sm">Delete</button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    <% } %>
  </div>
</div>

<div class="card card--warning mt-6">
  <div class="card__body">
    <p class="text-sm">
      <strong>Security notice:</strong>
      Secret values are encrypted with AES-256-GCM and cannot be retrieved or displayed after storage.
      To rotate a secret, delete it and re-add it with the new value.
      Secrets are injected into your container at runtime only — they are never written to disk or included in build artifacts.
    </p>
  </div>
</div>
