<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Project Settings</h1>
    <p class="page-header__subtitle"><%= project.slug %></p>
  </div>
  <a href="/projects/<%= project.slug %>" class="button button--secondary">Back to Project</a>
</div>

<div class="card card--form-narrow">
  <div class="card__header">
    <span class="card__title">General</span>
  </div>
  <div class="card__body">
    <%- include('../../partials/form-errors', { errors }) %>

    <form method="POST" action="/projects/<%= project.slug %>/update" novalidate>
      <%- include('../../partials/csrf-field') %>

      <div class="form-field form-field--floating">
        <label for="name" class="form-label form-label--required">Project name</label>
        <input
          type="text"
          id="name"
          name="name"
          class="form-input<%= errors.name ? ' form-input--error' : '' %>"
          value="<%= values.name %>"
          maxlength="100"
          placeholder=" "
          required
          aria-describedby="<%= errors.name ? 'name-error' : '' %>"
        />
        <% if (errors.name) { %>
        <span id="name-error" class="form-error" role="alert"><%= errors.name %></span>
        <% } %>
      </div>

      <div class="form-actions mt-6">
        <button type="submit" class="button button--primary">Save Settings</button>
      </div>
    </form>
  </div>
</div>

<div class="card card--danger mt-6">
  <div class="card__body">
    <h2 class="card__title mb-2">Danger Zone</h2>
    <div class="danger-action">
      <div>
        <strong>Delete this project</strong>
        <p class="text-sm text-muted">
          Permanently stops the running application and deletes all deployments,
          domains, secrets, and membership records. This cannot be undone.
        </p>
      </div>
    </div>
    <form method="POST" action="/projects/<%= project.slug %>/delete"
          data-confirm="This permanently deletes &quot;<%= project.name %>&quot; and all of its data. This cannot be undone."
          data-confirm-title="Delete project"
          data-confirm-accept-label="Delete Project"
          data-confirm-pending-label="Deleting..."
          data-confirm-variant="danger"
          class="mt-4">
      <%- include('../../partials/csrf-field') %>
      <div class="form-field form-field--floating">
        <label for="confirmSlug" class="form-label">
          Type <code class="code-inline"><%= project.slug %></code> to confirm
        </label>
        <input
          type="text"
          id="confirmSlug"
          name="confirmSlug"
          class="form-input"
          autocomplete="off"
          placeholder=" "
        />
      </div>
      <button type="submit" class="button button--danger button--sm">Delete Project</button>
    </form>
  </div>
</div>
