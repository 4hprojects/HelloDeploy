<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">
      <%= project.name %>
      <%- include('../../partials/status-badge', { status: project.status }) %>
    </h1>
    <p class="page-header__subtitle text-muted text-sm"><%= project.slug %></p>
  </div>
  <% if (membership.role === 'OWNER') { %>
  <div class="button-group">
    <a href="/projects/<%= project.slug %>/edit" class="button button--secondary">Settings</a>
  </div>
  <% } %>
</div>

<div class="project-detail-grid">
  <div class="card">
    <div class="card__header">
      <span class="card__title">Quick Links</span>
    </div>
    <div class="card__body">
      <nav class="quick-links">
        <a href="/projects/<%= project.slug %>/deployments" class="table-link text-sm">Deployments</a>
        <a href="/projects/<%= project.slug %>/repository" class="table-link text-sm">Repository</a>
        <a href="/projects/<%= project.slug %>/detection" class="table-link text-sm">Detection</a>
        <% if (membership.role === 'OWNER') { %>
          <a href="/projects/<%= project.slug %>/environment" class="table-link text-sm">Environment</a>
          <a href="/projects/<%= project.slug %>/members" class="table-link text-sm">Members</a>
          <a href="/projects/<%= project.slug %>/deploy-hook" class="table-link text-sm">Deploy Hook</a>
        <% } %>
      </nav>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <span class="card__title">Project Info</span>
    </div>
    <div class="card__body">
      <dl class="detail-list">
        <dt>Status</dt>
        <dd><%- include('../../partials/status-badge', { status: project.status }) %></dd>

        <dt>Slug</dt>
        <dd><code class="code-inline"><%= project.slug %></code></dd>

        <dt>Your role</dt>
        <dd><span class="role-pill"><%= membership.role %></span></dd>

        <dt>Runtime</dt>
        <dd>
          <% if (project.runtimeType) { %>
            <%- include('../../partials/status-badge', { status: project.runtimeType }) %>
          <% } else { %>
            <a href="/projects/<%= project.slug %>/detection" class="table-link text-sm">Run detection</a>
          <% } %>
        </dd>

        <dt>Deployment mode</dt>
        <dd><%= project.deploymentMode %></dd>

        <dt>Created</dt>
        <dd><%= new Date(project.createdAt).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }) %></dd>
      </dl>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <span class="card__title">Repository</span>
      <% if (membership.role === 'OWNER') { %>
        <a href="/projects/<%= project.slug %>/repository" class="button button--ghost button--sm">Manage</a>
      <% } %>
    </div>
    <div class="card__body">
      <% if (locals.repository && repository) { %>
        <dl class="detail-list">
          <dt>Repository</dt>
          <dd><code class="code-inline"><%= repository.fullName %></code></dd>

          <dt>Branch</dt>
          <dd><code class="code-inline"><%= project.productionBranch %></code></dd>

          <dt>Latest commit</dt>
          <dd>
            <% if (repository.lastCommitSha) { %>
              <code class="code-inline"><%= repository.lastCommitSha.slice(0, 7) %></code>
              <% if (repository.lastCommitMessage) { %>
                <span class="text-muted text-sm"><%= repository.lastCommitMessage %></span>
              <% } %>
            <% } else { %>
              <span class="text-muted text-sm">No commits yet</span>
            <% } %>
          </dd>

          <% if (locals.newCommitAvailable && newCommitAvailable) { %>
          <dt>New commit</dt>
          <dd>
            <span class="status-badge status-badge--queued">New commit available</span>
          </dd>
          <% } %>
        </dl>
      <% } else { %>
        <div class="empty-state empty-state--compact">
          <p class="empty-state__title">No repository connected</p>
          <p class="empty-state__description">Connect source code before detection or deployment.</p>
          <ul class="empty-state__steps">
            <li>Install or update GitHub App access.</li>
            <li>Select a repository and production branch.</li>
            <li>Run detection after the repository is connected.</li>
          </ul>
          <% if (membership.role === 'OWNER') { %>
          <div class="empty-state__actions">
            <a href="/projects/<%= project.slug %>/repository" class="button button--secondary button--sm">Connect Repository</a>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <span class="card__title">Deployment mode</span>
    </div>
    <div class="card__body">
      <p class="text-sm text-muted mb-4">
        <% if (project.deploymentMode === 'AUTOMATIC') { %>
          Pushes to the production branch trigger automatic deployment.
        <% } else if (project.deploymentMode === 'APPROVAL_REQUIRED') { %>
          Deploys require admin approval before executing.
        <% } else { %>
          Deploys are triggered manually only.
        <% } %>
      </p>
      <% if (membership.role === 'OWNER') { %>
      <form method="POST" action="/projects/<%= project.slug %>/deployment-mode">
        <%- include('../../partials/csrf-field') %>
        <div class="button-group">
          <% ['MANUAL', 'AUTOMATIC', 'APPROVAL_REQUIRED'].forEach(mode => { %>
          <button type="submit" name="deploymentMode" value="<%= mode %>"
                  class="button button--sm <%= project.deploymentMode === mode ? 'button--primary' : 'button--secondary' %>">
            <%= mode.charAt(0) + mode.slice(1).toLowerCase().replace('_', ' ') %>
          </button>
          <% }) %>
        </div>
      </form>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <span class="card__title">Notifications</span>
    </div>
    <div class="card__body">
      <p class="text-sm text-muted mb-4">
        <% if (project.notificationPreference === 'FAILURE_ONLY') { %>
          You'll only be emailed when a deployment fails.
        <% } else if (project.notificationPreference === 'NONE') { %>
          Deployment email notifications are turned off for this project.
        <% } else { %>
          You'll be emailed on every deployment outcome.
        <% } %>
      </p>
      <% if (membership.role === 'OWNER') { %>
      <form method="POST" action="/projects/<%= project.slug %>/notification-preference">
        <%- include('../../partials/csrf-field') %>
        <div class="button-group">
          <% ['ALL', 'FAILURE_ONLY', 'NONE'].forEach(pref => { %>
          <button type="submit" name="notificationPreference" value="<%= pref %>"
                  class="button button--sm <%= (project.notificationPreference || 'ALL') === pref ? 'button--primary' : 'button--secondary' %>">
            <%= pref === 'ALL' ? 'All' : pref === 'FAILURE_ONLY' ? 'Failures only' : 'None' %>
          </button>
          <% }) %>
        </div>
      </form>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card__header">
      <span class="card__title">Deployments</span>
      <a href="/projects/<%= project.slug %>/deployments" class="button button--ghost button--sm">View all</a>
    </div>
    <div class="card__body">
      <% if (locals.deployments && deployments.length > 0) { %>
        <div class="table-wrapper table-responsive table-responsive--flush">
        <table class="table table--responsive">
          <thead>
            <tr><th scope="col">#</th><th scope="col">Status</th><th scope="col">Commit</th><th scope="col">Started</th></tr>
          </thead>
          <tbody>
            <% deployments.slice(0, 5).forEach(d => { %>
            <tr>
              <td class="text-muted text-sm" data-label="#"><%= d.sequenceNumber %></td>
              <td data-label="Status"><%- include('../../partials/status-badge', { status: d.status }) %></td>
              <td data-label="Commit"><code class="code-inline"><%= d.commitSha ? d.commitSha.slice(0, 7) : '—' %></code></td>
              <td class="text-muted text-sm" data-label="Started"><%= d.startedAt ? new Date(d.startedAt).toLocaleDateString('en-GB') : '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      <% } else { %>
        <div class="empty-state empty-state--compact">
          <p class="empty-state__title">No deployments yet</p>
          <p class="empty-state__description">Prepare the project, then deploy the latest commit.</p>
          <ul class="empty-state__steps">
            <li>Connect a repository.</li>
            <li>Run detection and add required secrets.</li>
            <li>Deploy from the deployments page.</li>
          </ul>
          <% if (membership.role === 'OWNER' || membership.role === 'MAINTAINER') { %>
          <div class="empty-state__actions">
            <a href="/projects/<%= project.slug %>/deployments" class="button button--secondary button--sm">Open Deployments</a>
          </div>
          <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<% if (membership.role === 'OWNER' && project.status === 'DRAFT') { %>
<div class="card mt-6">
  <div class="card__body">
    <h2 class="card__title mb-2">Submit for Review</h2>
    <p class="text-sm text-muted mb-4">Once your project is configured, submit it for admin review to enable deployments.</p>
    <form method="POST" action="/projects/<%= project.slug %>/submit-review">
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--primary" data-pending-label="Submitting...">Submit for Review</button>
    </form>
  </div>
</div>
<% } %>

<% if (membership.role === 'OWNER' && project.status !== 'ARCHIVED') { %>
<div class="card mt-6">
  <div class="card__header">
    <h2 class="card__title">Maintenance Mode</h2>
    <span class="badge <%= project.maintenanceMode?.enabled ? 'badge--warning' : 'badge--success' %>">
      <%= project.maintenanceMode?.enabled ? 'Enabled' : 'Disabled' %>
    </span>
  </div>
  <div class="card__body">
    <% if (project.maintenanceMode?.enabled) { %>
    <p class="text-sm mb-4">
      Visitors to this project's URL see a maintenance page instead of the app. The running
      container is not stopped — disabling maintenance instantly restores traffic.
    </p>
    <% if (project.maintenanceMode.message) { %>
    <p class="text-muted text-sm mb-4"><%= project.maintenanceMode.message %></p>
    <% } %>
    <form method="POST" action="/projects/<%= project.slug %>/maintenance/disable"
          data-confirm="Disable maintenance mode and resume traffic to this project?"
          data-confirm-title="Disable maintenance"
          data-confirm-accept-label="Disable Maintenance"
          data-confirm-pending-label="Disabling..."
          data-confirm-variant="success">
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--success">Disable Maintenance</button>
    </form>
    <% } else { %>
    <form method="POST" action="/projects/<%= project.slug %>/maintenance/enable"
          data-confirm="Enable maintenance mode? Visitors will see a maintenance page instead of the app."
          data-confirm-title="Enable maintenance"
          data-confirm-accept-label="Enable Maintenance"
          data-confirm-pending-label="Enabling..."
          data-confirm-variant="warning">
      <%- include('../../partials/csrf-field') %>
      <div class="form-field form-field--floating mb-4">
        <label class="form-label" for="maintenance-message">Custom message (optional)</label>
        <input id="maintenance-message" name="message" class="form-input"
               maxlength="200"
               placeholder=" ">
      </div>
      <button type="submit" class="button button--warning">Enable Maintenance</button>
    </form>
    <% } %>
  </div>
</div>
<% } %>

<% if (membership.role === 'OWNER' && project.status !== 'ARCHIVED') { %>
<div class="card card--danger mt-6">
  <div class="card__body">
    <h2 class="card__title mb-2">Danger Zone</h2>
    <div class="danger-action">
      <div>
        <strong>Archive this project</strong>
        <p class="text-sm text-muted">The application will be stopped and the project will be read-only.</p>
      </div>
      <form method="POST" action="/projects/<%= project.slug %>/archive"
            data-confirm="Archive <%= project.name %>? The application will be stopped and the project will become read-only."
            data-confirm-title="Archive project"
            data-confirm-accept-label="Archive Project"
            data-confirm-pending-label="Archiving..."
            data-confirm-variant="danger">
        <%- include('../../partials/csrf-field') %>
        <button type="submit" class="button button--danger button--sm">Archive</button>
      </form>
    </div>
  </div>
</div>
<% } %>
