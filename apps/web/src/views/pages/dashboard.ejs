<div class="page-header page-header--actions">
  <div>
    <h1 class="page-header__title">Dashboard</h1>
    <p class="page-header__subtitle">Welcome back, <%= locals.user?.firstName ?? 'there' %>.</p>
  </div>
  <a href="/projects/new" class="button button--primary">New Project</a>
</div>

<% if (projects.length === 0) { %>
<div class="empty-state">
  <div class="empty-state__icon" aria-hidden="true">◫</div>
  <h2 class="empty-state__title">No projects yet</h2>
  <p class="empty-state__description">Start with a project, then connect source code and run detection before the first deploy.</p>
  <ul class="empty-state__steps">
    <li>Create a project name and slug.</li>
    <li>Connect the GitHub repository you want to deploy.</li>
    <li>Run detection, add required secrets, and deploy when ready.</li>
  </ul>
  <div class="empty-state__actions">
    <a href="/projects/new" class="button button--primary">Create Project</a>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="card__header">
    <span class="card__title">Your Projects</span>
    <a href="/projects" class="button button--ghost button--sm">View all</a>
  </div>
  <div class="table-wrapper table-responsive table-responsive--flush">
    <table class="table table--responsive">
      <thead>
        <tr>
          <th scope="col">Name</th>
          <th scope="col">Status</th>
          <th scope="col">Role</th>
          <th scope="col">Created</th>
          <th scope="col"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody>
        <% projects.slice(0, 5).forEach(({ project, role }) => { %>
        <tr>
          <td data-label="Name">
            <a href="/projects/<%= project.slug %>" class="table-link"><%= project.name %></a>
            <span class="text-muted text-xs d-block"><%= project.slug %></span>
          </td>
          <td data-label="Status">
            <%- include('../partials/status-badge', { status: project.status }) %>
          </td>
          <td data-label="Role"><span class="role-pill"><%= role %></span></td>
          <td class="text-muted text-sm" data-label="Created"><%= new Date(project.createdAt).toLocaleDateString('en-GB') %></td>
          <td class="text-right" data-label="Actions">
            <a href="/projects/<%= project.slug %>" class="button button--ghost button--sm">Open</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>
