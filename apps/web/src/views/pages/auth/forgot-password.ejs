<div class="auth-form">
  <h1 class="auth-form__title">Forgot Password?</h1>
  <p class="auth-form__subtitle">
    Enter your email address and we'll send you a reset code.
  </p>

  <%- include('../../partials/form-errors', { errors: typeof errors !== 'undefined' ? errors : {} }) %>

  <form method="POST" action="/auth/forgot-password" novalidate id="forgot-form">
    <%- include('../../partials/csrf-field') %>

    <%- include('../../partials/form-field', {
      fieldId: 'email',
      label: 'Email Address',
      type: 'email',
      name: 'email',
      value: '',
      autocomplete: 'email',
      required: true,
      error: typeof errors !== 'undefined' ? errors.email : null
    }) %>

    <button type="submit" class="button button--primary button--full mt-6" id="submit-btn">
      Send Reset Code
    </button>
  </form>

  <p class="mt-4 text-center">
    <a href="/auth/sign-in">Back to Sign In</a>
  </p>
</div>

<script>
  (function () {
    const form = document.getElementById('forgot-form');
    const btn = document.getElementById('submit-btn');
    if (!form || !btn) return;
    form.addEventListener('submit', function () {
      btn.disabled = true;
      btn.textContent = 'Sending…';
    });
  })();
</script>
