<div class="auth-form">
  <h1 class="auth-form__title">New Password</h1>
  <p class="auth-form__subtitle">Choose a strong password for your account.</p>

  <%- include('../../partials/form-errors', { errors: typeof errors !== 'undefined' ? errors : {} }) %>

  <form method="POST" action="/auth/new-password" novalidate id="new-password-form">
    <%- include('../../partials/csrf-field') %>

    <%- include('../../partials/password-field', {
      fieldId: 'password',
      fieldName: 'password',
      label: 'New Password',
      required: true,
      autocomplete: 'new-password',
      error: typeof errors !== 'undefined' ? errors.password : null
    }) %>

    <%- include('../../partials/password-requirements') %>

    <%- include('../../partials/password-field', {
      fieldId: 'confirmPassword',
      fieldName: 'confirmPassword',
      label: 'Confirm New Password',
      required: true,
      autocomplete: 'new-password',
      error: typeof errors !== 'undefined' ? errors.confirmPassword : null
    }) %>

    <button type="submit" class="button button--primary button--full mt-6" id="submit-btn" data-pending-label="Saving...">
      Update Password
    </button>
  </form>
</div>
