<div class="hero">
  <div class="hero__content">
    <h1 class="hero__title">Deploy web apps from GitHub in minutes</h1>
    <p class="hero__subtitle">
      HelloDeploy is a self-hosted platform that builds, deploys, and manages your
      web applications — with zero vendor lock-in.
    </p>
    <div class="button-group mt-6">
      <a href="/auth/create-account" class="button button--primary button--lg">Get Started</a>
      <a href="/auth/sign-in" class="button button--secondary button--lg">Sign In</a>
    </div>
  </div>
</div>

