<div class="page-header">
  <div>
    <h1 class="page-header__title">Quota Override</h1>
    <p class="page-header__subtitle text-muted text-sm">
      <%= scopeType %> / <code class="code-inline"><%= scopeId %></code>
    </p>
  </div>
</div>

<% const quotaFields = [
  ['maxOwnedProjects', 'Max Owned Projects'],
  ['maxRunningApps', 'Max Running Apps'],
  ['maxProjectMembers', 'Max Project Members'],
  ['memoryMb', 'Memory (MB)'],
  ['cpuCores', 'CPU Cores'],
  ['deploymentsPerMonth', 'Deployments / Month'],
  ['buildTimeoutSeconds', 'Build Timeout (seconds)'],
  ['maxCustomDomains', 'Max Custom Domains'],
  ['maxRollbackReleases', 'Max Rollback Releases'],
  ['logRetentionDays', 'Log Retention (days)'],
]; %>
<% const quotaValue = (key) => quota?.[key] ?? ''; %>

<div class="card">
  <div class="card__header">
    <span class="card__title">Current Limits</span>
  </div>
  <div class="card__body">
    <% if (quota && quotaFields.some(([key]) => quota[key] !== null && quota[key] !== undefined)) { %>
    <dl class="detail-list">
      <% quotaFields.forEach(([key, label]) => { if (quota[key] !== null && quota[key] !== undefined) { %>
      <dt><%= label %></dt>
      <dd><%= quota[key] %></dd>
      <% } }) %>
    </dl>
    <% if (consumption && Object.keys(consumption).length > 0) { %>
    <h3 class="text-sm mt-4 mb-2">Current Consumption</h3>
    <dl class="detail-list">
      <% Object.entries(consumption).forEach(([k, v]) => { %>
      <dt><%= k %></dt>
      <dd><%= v %></dd>
      <% }) %>
    </dl>
    <% } %>
    <% if (quota.reason) { %>
    <p class="text-sm text-muted mt-4">Reason: <%= quota.reason %></p>
    <% } %>
    <% } else { %>
    <p class="text-muted text-sm">No custom quota override set. Platform defaults apply.</p>
    <% } %>
  </div>
</div>

<div class="card mt-6">
  <div class="card__header">
    <span class="card__title">Set Quota Override</span>
  </div>
  <div class="card__body">
    <form method="POST" action="/admin/quotas/<%= scopeType %>/<%= scopeId %>">
      <%- include('../../partials/csrf-field') %>

      <div class="form-grid form-grid--2">
        <% const quotaFieldConfig = [
          ['maxOwnedProjects', 'Max Owned Projects', 'Maximum projects this user can own.', { step: '1' }],
          ['maxRunningApps', 'Max Running Apps', 'Maximum apps this scope can keep running at the same time.', { step: '1' }],
          ['maxProjectMembers', 'Max Project Members', 'Maximum members allowed on a project.', { step: '1' }],
          ['memoryMb', 'Memory (MB)', 'Runtime memory limit in megabytes.', { step: '1' }],
          ['cpuCores', 'CPU Cores', 'CPU core allocation for runtime containers.', { step: '0.1' }],
          ['deploymentsPerMonth', 'Deployments / Month', 'Maximum deployment attempts allowed each month.', { step: '1' }],
          ['buildTimeoutSeconds', 'Build Timeout (seconds)', 'Maximum build time before a deployment is stopped.', { step: '1' }],
          ['maxCustomDomains', 'Max Custom Domains', 'Maximum verified custom domains allowed.', { step: '1' }],
          ['maxRollbackReleases', 'Max Rollback Releases', 'Number of healthy releases retained for rollback.', { step: '1' }],
          ['logRetentionDays', 'Log Retention (days)', 'How long deployment logs should be retained.', { step: '1' }],
        ]; %>
        <% quotaFieldConfig.forEach(([key, label, tooltip, attrs]) => { %>
        <div class="form-group form-group--floating">
          <label class="form-label" for="<%= key %>"><%= label %></label>
          <input type="number" id="<%= key %>" name="<%= key %>"
                 class="form-input<%= (typeof errors !== 'undefined' && errors?.[key]) ? ' form-input--error' : '' %>"
                 data-tooltip="<%= tooltip %>"
                 min="0" step="<%= attrs.step %>" value="<%= quotaValue(key) %>" placeholder="Platform default"
                 <% if (typeof errors !== 'undefined' && errors?.[key]) { %>aria-invalid="true" aria-describedby="<%= key %>-error"<% } %> />
          <% if (typeof errors !== 'undefined' && errors?.[key]) { %>
          <p class="form-error" id="<%= key %>-error" role="alert"><%= errors[key] %></p>
          <% } %>
        </div>
        <% }) %>
      </div>

      <div class="form-group form-group--floating mt-4">
        <label class="form-label" for="reason">Reason for override</label>
        <input type="text" id="reason" name="reason" class="form-input"
               value="<%= quota?.reason ?? '' %>" placeholder="Optional — appears in audit log" />
      </div>

      <div class="button-group mt-6">
        <button type="submit" class="button button--primary" data-pending-label="Saving...">Save Quota Override</button>
        <a href="/admin/users" class="button button--ghost">Cancel</a>
      </div>
    </form>
  </div>
</div>
