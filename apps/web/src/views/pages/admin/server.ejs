<div class="page-header">
  <h1 class="page-header__title">Server &amp; Queue</h1>
  <p class="page-header__subtitle text-muted text-sm">
    Collected at <%= server.collectedAt ? new Date(server.collectedAt).toLocaleTimeString('en-GB') : '—' %>
    &nbsp;·&nbsp; Uptime: <%= server.uptime?.human ?? '—' %>
  </p>
</div>

<!-- Maintenance mode -->
<div class="card mb-6">
  <div class="card__header">
    <h2 class="card__title">Maintenance Mode</h2>
    <span class="badge <%= maintenance?.enabled ? 'badge--warning' : 'badge--success' %>">
      <%= maintenance?.enabled ? 'Enabled' : 'Disabled' %>
    </span>
  </div>
  <div class="card__body">
    <% if (maintenance?.enabled) { %>
    <p class="text-sm mb-4">
      Mutating user actions are paused. Super Admin actions and safe read-only requests remain available.
    </p>
    <% if (maintenance.message) { %>
    <p class="text-muted text-sm mb-4"><%= maintenance.message %></p>
    <% } %>
    <form method="POST" action="/admin/server/maintenance/disable"
          data-confirm="Disable maintenance mode and allow user mutations again?"
          data-confirm-title="Disable maintenance"
          data-confirm-accept-label="Disable Maintenance"
          data-confirm-pending-label="Disabling..."
          data-confirm-variant="success">
      <%- include('../../partials/csrf-field') %>
      <button type="submit" class="button button--success" data-tooltip="Allow users to create, update, and deploy again.">Disable Maintenance</button>
    </form>
    <% } else { %>
    <form method="POST" action="/admin/server/maintenance/enable"
          data-confirm="Enable maintenance mode? User mutations will be paused."
          data-confirm-title="Enable maintenance"
          data-confirm-accept-label="Enable Maintenance"
          data-confirm-pending-label="Enabling..."
          data-confirm-variant="warning">
      <%- include('../../partials/csrf-field') %>
      <div class="form-group form-group--floating mb-4">
        <label class="form-label" for="maintenance-message">User-facing message</label>
        <input id="maintenance-message" name="message" class="form-input"
               maxlength="300"
               placeholder=" "
               value="HelloDeploy is temporarily in maintenance mode. Please try again later.">
      </div>
      <button type="submit" class="button button--warning" data-tooltip="Pause user write actions while keeping safe read-only access available.">Enable Maintenance</button>
    </form>
    <% } %>
  </div>
</div>

<!-- System stats -->
<div class="stats-grid mb-6">
  <% if (server.cpu) { %>
  <div class="stat-card">
    <span class="stat-card__value"><%= server.cpu.load1 %></span>
    <span class="stat-card__label">Load avg (1m)</span>
    <span class="stat-card__sub"><%= server.cpu.cores %> CPU cores</span>
  </div>
  <% } %>

  <% if (server.memory) { %>
  <div class="stat-card<%= server.memory.usedPercent > 85 ? ' stat-card--alert' : '' %>">
    <span class="stat-card__value"><%= server.memory.usedPercent %>%</span>
    <span class="stat-card__label">Memory Used</span>
    <span class="stat-card__sub"><%= server.memory.usedMb %> / <%= server.memory.totalMb %> MB</span>
  </div>
  <% } %>

  <% if (server.disk) { %>
  <div class="stat-card<%= server.disk.usedPercent > 85 ? ' stat-card--alert' : '' %>">
    <span class="stat-card__value"><%= server.disk.usedPercent %>%</span>
    <span class="stat-card__label">Disk Used</span>
    <span class="stat-card__sub"><%= server.disk.usedGb %> / <%= server.disk.totalGb %> GB</span>
  </div>
  <% } %>

  <div class="stat-card">
    <span class="stat-card__value"><%= server.running ?? '—' %></span>
    <span class="stat-card__label">Running Containers</span>
  </div>
</div>

<!-- Worker readiness -->
<div class="card mb-6">
  <div class="card__header">
    <h2 class="card__title">Deployment Worker</h2>
    <span class="badge <%= server.worker?.ready ? 'badge--success' : 'badge--danger' %>">
      <%= server.worker?.ready ? 'Ready' : 'Unavailable' %>
    </span>
  </div>
  <div class="card__body">
    <% if (server.worker?.ready) { %>
    <p class="text-sm">
      <%= server.worker.connectedWorkers %> worker<%= server.worker.connectedWorkers === 1 ? '' : 's' %>
      connected to the deployment queue.
    </p>
    <% } else if (server.worker?.connectedWorkers === null) { %>
    <p class="text-muted text-sm">Worker readiness could not be checked. Verify Redis and queue availability.</p>
    <% } else { %>
    <p class="text-muted text-sm">No deployment worker is connected. Queued jobs will not be processed.</p>
    <% } %>
  </div>
</div>

<!-- Queue management -->
<div class="card mb-6">
  <div class="card__header">
    <h2 class="card__title">Deployment Queue</h2>
    <% if (server.queue) { %>
    <span class="badge <%= server.queue.paused ? 'badge--warning' : 'badge--success' %>">
      <%= server.queue.paused ? 'Paused' : 'Active' %>
    </span>
    <% } %>
  </div>
  <div class="card__body">
    <% if (server.queue) { %>
    <div class="stats-grid stats-grid--sm mb-4">
      <div class="stat-card stat-card--sm">
        <span class="stat-card__value"><%= server.queue.waiting ?? 0 %></span>
        <span class="stat-card__label">Waiting</span>
      </div>
      <div class="stat-card stat-card--sm">
        <span class="stat-card__value"><%= server.queue.active ?? 0 %></span>
        <span class="stat-card__label">Active</span>
      </div>
      <div class="stat-card stat-card--sm">
        <span class="stat-card__value"><%= server.queue.delayed ?? 0 %></span>
        <span class="stat-card__label">Delayed</span>
      </div>
      <div class="stat-card stat-card--sm">
        <span class="stat-card__value"><%= server.queue.failed ?? 0 %></span>
        <span class="stat-card__label">Failed</span>
      </div>
    </div>
    <% } else { %>
    <p class="text-muted text-sm">Queue is not available (Redis may be disconnected).</p>
    <% } %>

    <div class="button-group">
      <% if (server.queue?.paused) { %>
      <form method="POST" action="/admin/server/queue/resume">
        <%- include('../../partials/csrf-field') %>
        <button type="submit" class="button button--success" data-pending-label="Resuming..." data-tooltip="Allow queued deployment jobs to start again.">Resume Queue</button>
      </form>
      <% } else { %>
      <form method="POST" action="/admin/server/queue/pause"
            data-confirm="Pause the deployment queue? Running jobs will finish, but no new jobs will start."
            data-confirm-title="Pause deployment queue"
            data-confirm-accept-label="Pause Queue"
            data-confirm-pending-label="Pausing..."
            data-confirm-variant="warning">
        <%- include('../../partials/csrf-field') %>
        <button type="submit" class="button button--warning" data-tooltip="Stop new deployment jobs from starting; running jobs can finish.">Pause Queue</button>
      </form>
      <% } %>
    </div>
  </div>
</div>
