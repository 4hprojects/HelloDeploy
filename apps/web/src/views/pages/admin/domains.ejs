<div class="page-header">
  <h1 class="page-header__title">Domain Approval Queue</h1>
</div>

<% if (domains.length === 0) { %>
<div class="card">
  <div class="card__body">
    <div class="empty-state">
      <p class="empty-state__title">No domains awaiting approval</p>
      <p class="empty-state__description">Verified custom domains will appear here for review before routing is activated.</p>
      <ul class="empty-state__steps">
        <li>Project owners add a custom domain from the project domain page.</li>
        <li>HelloDeploy waits for DNS TXT verification.</li>
        <li>Verified domains appear here for approval or rejection.</li>
      </ul>
    </div>
  </div>
</div>
<% } else { %>
<div class="card">
  <div class="card__body">
    <div class="table-wrapper table-responsive table-responsive--flush">
    <table class="table table--responsive">
      <thead>
        <tr>
          <th scope="col">Hostname</th>
          <th scope="col">Project</th>
          <th scope="col">Verified</th>
          <th scope="col"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody>
        <% domains.forEach(d => { %>
        <tr>
          <td data-label="Hostname"><code class="code-inline"><%= d.hostnameNormalized %></code></td>
          <td data-label="Project">
            <% if (d.projectId && d.projectId.name) { %>
              <a href="/projects/<%= d.projectId.slug %>" class="table-link"><%= d.projectId.name %></a>
            <% } else { %>
              <span class="text-muted">Unknown</span>
            <% } %>
          </td>
          <td class="text-muted text-sm" data-label="Verified">
            <% if (d.verifiedAt) { %>
              <%= new Date(d.verifiedAt).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }) %>
            <% } else { %> — <% } %>
          </td>
          <td class="text-right" data-label="Actions">
            <div class="button-group button-group--sm">
              <form method="POST" action="/admin/domains/<%= d._id %>/approve"
                    data-confirm="Approve <%= d.hostnameNormalized %> and queue route activation?"
                    data-confirm-title="Approve domain"
                    data-confirm-accept-label="Approve Domain"
                    data-confirm-pending-label="Approving..."
                    data-confirm-variant="success">
                <%- include('../../partials/csrf-field') %>
                <button type="submit" class="button button--success button--sm" data-tooltip="Approve this verified domain and queue route activation.">Approve</button>
              </form>
              <form method="POST" action="/admin/domains/<%= d._id %>/reject"
                    data-confirm="Reject <%= d.hostnameNormalized %> and keep routing inactive?"
                    data-confirm-title="Reject domain"
                    data-confirm-accept-label="Reject Domain"
                    data-confirm-pending-label="Rejecting..."
                    data-confirm-variant="danger">
                <%- include('../../partials/csrf-field') %>
                <input type="text" name="reason" placeholder="Rejection reason (optional)" class="form-input form-input--sm" data-tooltip="Optional note recorded with the rejection.">
                <button type="submit" class="button button--danger button--sm" data-tooltip="Reject this domain request and keep routing inactive.">Reject</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </div>
</div>
<% } %>
