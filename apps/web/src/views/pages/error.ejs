<div class="page-header">
  <h1 class="page-header__title"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
</div>

<div class="card">
  <div class="card__body">
    <p><%= typeof message !== 'undefined' ? message : 'An error occurred.' %></p>
    <p class="mt-4">
      <a href="/" class="button button--secondary">Go to Dashboard</a>
    </p>
  </div>
</div>
