<% var _path = locals.currentPath || ''; %>
<% var _user = locals.user || null; %>
<nav class="sidebar" id="sidebar" aria-label="Application navigation">
  <ul class="sidebar__nav" role="list">
    <li>
      <a
        href="/dashboard"
        class="sidebar__link"
        <%= _path === '/dashboard' ? 'aria-current="page"' : '' %>
      >
        <%- include('icon', { name: 'dashboard', className: 'sidebar__icon' }) %>
        <span>Dashboard</span>
      </a>
    </li>
    <li>
      <a
        href="/projects"
        class="sidebar__link"
        <%= _path.startsWith('/projects') ? 'aria-current="page"' : '' %>
      >
        <%- include('icon', { name: 'projects', className: 'sidebar__icon' }) %>
        <span>Projects</span>
      </a>
    </li>
  </ul>

  <% if (locals.currentProject && currentProject) { %>
  <div class="sidebar__section">
    <p class="sidebar__section-title"><%= currentProject.name %></p>
    <ul class="sidebar__nav" role="list">
      <% (locals.projectNavigation || []).forEach((item) => { %>
        <li>
          <a href="<%= item.href %>"
             class="sidebar__link"
             <%= item.active ? 'aria-current="page"' : '' %>>
            <%- include('icon', { name: item.icon, className: 'sidebar__icon' }) %>
            <span><%= item.label %></span>
          </a>
        </li>
      <% }) %>
    </ul>
  </div>
  <% } %>

  <% if (_user && (_user.platformRole === 'ADMIN' || _user.platformRole === 'SUPER_ADMIN')) { %>
  <div class="sidebar__section">
    <p class="sidebar__section-title">Admin</p>
    <ul class="sidebar__nav" role="list">
      <li>
        <a
          href="/admin"
          class="sidebar__link"
          <%= _path === '/admin' ? 'aria-current="page"' : '' %>
        >
          <%- include('icon', { name: 'dashboard', className: 'sidebar__icon' }) %>
          <span>Overview</span>
        </a>
      </li>
      <li>
        <a
          href="/admin/users"
          class="sidebar__link"
          <%= _path.startsWith('/admin/users') ? 'aria-current="page"' : '' %>
        >
          <%- include('icon', { name: 'users', className: 'sidebar__icon' }) %>
          <span>Users</span>
        </a>
      </li>
      <li>
        <a
          href="/admin/projects"
          class="sidebar__link"
          <%= _path.startsWith('/admin/projects') ? 'aria-current="page"' : '' %>
        >
          <%- include('icon', { name: 'projects', className: 'sidebar__icon' }) %>
          <span>All Projects</span>
        </a>
      </li>
      <li>
        <a
          href="/admin/approval-requests"
          class="sidebar__link"
          <%= _path.startsWith('/admin/approval-requests') ? 'aria-current="page"' : '' %>
        >
          <%- include('icon', { name: 'reviews', className: 'sidebar__icon' }) %>
          <span>Reviews</span>
        </a>
      </li>
      <li>
        <a
          href="/admin/audit-events"
          class="sidebar__link"
          <%= currentPath.startsWith('/admin/audit-events') ? 'aria-current="page"' : '' %>
        >
          <%- include('icon', { name: 'audit', className: 'sidebar__icon' }) %>
          <span>Audit Log</span>
        </a>
      </li>
      <li>
        <a
          href="/admin/server"
          class="sidebar__link"
          <%= currentPath.startsWith('/admin/server') ? 'aria-current="page"' : '' %>
        >
          <%- include('icon', { name: 'server', className: 'sidebar__icon' }) %>
          <span>Server</span>
        </a>
      </li>
    </ul>
  </div>
  <% } %>

  <div class="sidebar__section">
    <ul class="sidebar__nav" role="list">
      <li>
        <form
          method="POST"
          action="/auth/sign-out"
          data-confirm="Are you sure you want to sign out?"
          data-confirm-title="Sign out"
          data-confirm-accept-label="Sign Out"
          data-confirm-pending-label="Signing out…"
          data-confirm-variant="warning"
        >
          <%- include('csrf-field') %>
          <button type="submit" class="sidebar__link sidebar__link--button">
            <%- include('icon', { name: 'logout', className: 'sidebar__icon' }) %>
            <span>Sign Out</span>
          </button>
        </form>
      </li>
    </ul>
  </div>
</nav>
