<%
  const _fieldId = typeof fieldId !== 'undefined' ? fieldId : 'password';
  const _name = typeof fieldName !== 'undefined' ? fieldName : 'password';
  const _label = typeof label !== 'undefined' ? label : 'Password';
  const _required = typeof required !== 'undefined' ? required : true;
  const _error = typeof error !== 'undefined' ? error : null;
  const _autocomplete = typeof autocomplete !== 'undefined' ? autocomplete : 'current-password';
%>
<div class="form-field form-field--floating">
  <label for="<%= _fieldId %>" class="form-label<% if (_required) { %> form-label--required<% } %>">
    <%= _label %>
  </label>
  <div class="password-wrapper">
    <input
      type="password"
      id="<%= _fieldId %>"
      name="<%= _name %>"
      class="form-input password-input<% if (_error) { %> form-input--error<% } %>"
      autocomplete="<%= _autocomplete %>"
      placeholder=" "
      <% if (_required) { %>aria-required="true"<% } %>
      <% if (_error) { %>aria-describedby="<%= _fieldId %>-error"<% } %>
    />
    <button
      type="button"
      class="password-toggle"
      aria-controls="<%= _fieldId %>"
      aria-pressed="false"
    >
      <span class="sr-only">Show password</span>
      <%- include('icon', { name: 'eye', className: 'password-toggle__icon' }) %>
    </button>
  </div>
  <% if (_error) { %>
  <p class="form-error" id="<%= _fieldId %>-error" role="alert"><%= _error %></p>
  <% } %>
</div>

<script>
  (function () {
    const btn = document.querySelector('[aria-controls="<%= _fieldId %>"]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      const input = document.getElementById('<%= _fieldId %>');
      const isShowing = input.type === 'text';
      input.type = isShowing ? 'password' : 'text';
      this.setAttribute('aria-pressed', String(!isShowing));
      this.querySelector('.sr-only').textContent = isShowing ? 'Show password' : 'Hide password';
    });
  })();
</script>
