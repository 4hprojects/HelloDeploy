<header class="header" role="banner">
  <div class="header__inner">
    <button type="button" class="header__menu-toggle" id="sidebar-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="sidebar" data-tooltip="Open or close the navigation menu">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
    <a href="/" class="header__brand" aria-label="HelloDeploy home">
      <%- include('brand-logo') %>
    </a>
    <nav class="header__nav" aria-label="Primary navigation">
      <button type="button" class="header__theme-toggle" id="theme-toggle" aria-label="Switch to dark theme" aria-pressed="false" data-tooltip="Switch to dark theme">
        <%- include('icon', { name: 'sun', className: 'theme-icon theme-icon--light' }) %>
        <%- include('icon', { name: 'moon', className: 'theme-icon theme-icon--dark' }) %>
      </button>
    </nav>
  </div>
</header>
