<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="HelloDeploy — self-hosted web application deployment" />
  <title><%= title ? `${title} — HelloDeploy` : 'HelloDeploy' %></title>

  <link rel="icon" type="image/svg+xml" href="/assets/icons/favicon.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="HelloDeploy" />
  <meta property="og:title" content="<%= title ? `${title} — HelloDeploy` : 'HelloDeploy' %>" />
  <meta property="og:description" content="Self-hosted web application deployment platform" />
  <meta property="og:image" content="/assets/icons/icon-512.png" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="<%= title ? `${title} — HelloDeploy` : 'HelloDeploy' %>" />
  <meta name="twitter:image" content="/assets/icons/icon-512.png" />
  <meta name="theme-color" content="#ffffff" />

  <!-- Theme applied before stylesheet parse to prevent flash -->
  <script>
    (function () {
      var root = document.documentElement;
      var storageKey = 'hd-theme';
      var theme = 'light';

      function syncThemeColor(nextTheme) {
        var meta = document.querySelector('meta[name="theme-color"]');
        if (meta) meta.setAttribute('content', nextTheme === 'dark' ? '#0f172a' : '#ffffff');
      }

      function applyTheme(nextTheme, persist) {
        var safeTheme = nextTheme === 'dark' ? 'dark' : 'light';
        root.setAttribute('data-theme', safeTheme);
        root.style.colorScheme = safeTheme;
        syncThemeColor(safeTheme);

        if (persist) {
          try {
            localStorage.setItem(storageKey, safeTheme);
          } catch (e) {}
        }

        try {
          window.dispatchEvent(new CustomEvent('hellodeploy:themechange', { detail: { theme: safeTheme } }));
        } catch (e) {}
      }

      try {
        var storedTheme = localStorage.getItem(storageKey);
        var prefersDark =
          window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (storedTheme === 'dark' || storedTheme === 'light') {
          theme = storedTheme;
        } else if (prefersDark) {
          theme = 'dark';
        }
      } catch (e) {}

      applyTheme(theme, false);
      window.__setHelloDeployTheme = applyTheme;
    })();
  </script>

  <link rel="stylesheet" href="/css/main.css" />
</head>
