  <p class="footer__text">
    &copy; <%= new Date().getFullYear() %> HelloDeploy &middot;
    <a href="/legal">Legal</a> &middot;
    <a href="/terms">Terms</a> &middot;
    <a href="/privacy">Privacy</a> &middot;
    <a href="/cookies">Cookies</a> &middot;
    <a href="/acceptable-use">Acceptable Use</a> &middot;
    <a href="/service-limits">Service Limits</a>
  </p>
</footer>

<div
  class="confirm-modal"
  id="confirm-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="confirm-modal-title"
  aria-describedby="confirm-modal-message"
  hidden
>
  <div class="confirm-modal__backdrop" data-confirm-cancel></div>
  <div class="confirm-modal__dialog" role="document" tabindex="-1">
    <div class="confirm-modal__body">
      <p class="confirm-modal__eyebrow">Confirm action</p>
      <h2 class="confirm-modal__title" id="confirm-modal-title">Continue?</h2>
      <p class="confirm-modal__message" id="confirm-modal-message"></p>
    </div>
    <div class="confirm-modal__actions">
      <button type="button" class="button button--ghost" data-confirm-cancel>Cancel</button>
      <button type="button" class="button button--danger" data-confirm-accept>Confirm</button>
    </div>
  </div>
</div>

<button
  type="button"
  class="scroll-top-button"
  id="scroll-top-button"
  aria-label="Scroll to top"
  data-tooltip="Back to top"
  hidden
>
  <%- include('icon', { name: 'up' }) %>
</button>
