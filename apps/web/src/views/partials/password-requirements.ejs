<ul class="password-requirements" aria-label="Password requirements" id="password-requirements">
  <li class="password-req" data-req="length" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    At least 8 characters
  </li>
  <li class="password-req" data-req="uppercase" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    One uppercase letter
  </li>
  <li class="password-req" data-req="lowercase" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    One lowercase letter
  </li>
  <li class="password-req" data-req="digit" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    One number
  </li>
</ul>
