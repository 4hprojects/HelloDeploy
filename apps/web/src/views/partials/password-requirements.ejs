<ul class="password-requirements" aria-label="Password requirements" id="password-requirements">
  <li class="password-req" data-req="length" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    At least 8 characters
  </li>
  <li class="password-req" data-req="uppercase" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    One uppercase letter
  </li>
  <li class="password-req" data-req="lowercase" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    One lowercase letter
  </li>
  <li class="password-req" data-req="digit" aria-live="polite">
    <span class="password-req__icon" aria-hidden="true">○</span>
    One number
  </li>
</ul>

<script>
  (function () {
    const input = document.getElementById('password');
    const items = document.querySelectorAll('.password-req');
    if (!input || !items.length) return;

    const checks = {
      length: (v) => v.length >= 8,
      uppercase: (v) => /[A-Z]/.test(v),
      lowercase: (v) => /[a-z]/.test(v),
      digit: (v) => /[0-9]/.test(v),
    };

    input.addEventListener('input', function () {
      items.forEach((item) => {
        const req = item.dataset.req;
        const met = checks[req] && checks[req](this.value);
        item.classList.toggle('password-req--met', met);
        item.querySelector('.password-req__icon').textContent = met ? '✓' : '○';
      });
    });
  })();
</script>
