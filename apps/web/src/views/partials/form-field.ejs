<%
  // Required locals: fieldId, label, type, name, value, autocomplete
  // Optional: required, hint, error, placeholder
  const _required = typeof required !== 'undefined' ? required : false;
  const _hint = typeof hint !== 'undefined' ? hint : null;
  const _error = typeof error !== 'undefined' ? error : null;
  const _placeholder = typeof placeholder !== 'undefined' ? placeholder : '';
  const _autocomplete = typeof autocomplete !== 'undefined' ? autocomplete : 'off';
  const _type = typeof type !== 'undefined' ? type : 'text';
  const _value = typeof value !== 'undefined' ? value : '';
%>
<div class="form-field">
  <label for="<%= fieldId %>" class="form-label<% if (_required) { %> form-label--required<% } %>">
    <%= label %>
  </label>
  <% if (_hint) { %>
  <p class="form-hint" id="<%= fieldId %>-hint"><%= _hint %></p>
  <% } %>
  <input
    type="<%= _type %>"
    id="<%= fieldId %>"
    name="<%= name %>"
    value="<%= _value %>"
    class="form-input<% if (_error) { %> form-input--error<% } %>"
    autocomplete="<%= _autocomplete %>"
    <% if (_required) { %>aria-required="true"<% } %>
    <% if (_error) { %>aria-describedby="<%= fieldId %>-error"<% } else if (_hint) { %>aria-describedby="<%= fieldId %>-hint"<% } %>
    <% if (_placeholder) { %>placeholder="<%= _placeholder %>"<% } %>
  />
  <% if (_error) { %>
  <p class="form-error" id="<%= fieldId %>-error" role="alert"><%= _error %></p>
  <% } %>
</div>
