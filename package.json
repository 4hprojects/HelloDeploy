{
  "name": "hellodeploy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"web,worker\" --prefix-colors \"cyan,yellow\" \"npm run dev -w @hellodeploy/web\" \"npm run dev -w @hellodeploy/worker\"",
    "start": "concurrently --names \"web,worker\" \"npm run start -w @hellodeploy/web\" \"npm run start -w @hellodeploy/worker\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "config:check": "node scripts/validate-config.js",
    "production:check": "node scripts/check-public-production.js",
    "test": "node scripts/run-tests.js",
    "test:watch": "node scripts/run-tests.js --watch"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.18.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "allowScripts": {
    "argon2@0.41.1": true,
    "msgpackr-extract@3.0.4": true
  }
}
